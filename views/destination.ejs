<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
    <meta charset="utf-8">
    <title>Popular Destinations - FMPG</title>
    <link rel="icon" href="/img/logo.png" type="image/icon type">
    
    <!-- Central Tailwind CSS & Theme Config -->
    <%- include('tailwind-head') %>
</head>

<body class="bg-bg-body text-text-primary min-h-screen flex flex-col transition-colors duration-300">
    <!-- Header -->
    <%- include('header') %>

    <!-- Destination Start -->
    <main class="flex-grow max-w-5xl mx-auto w-full px-4 py-12 md:py-16 space-y-12">
        <div class="text-center space-y-2 animate-fade-in-up">
            <span class="inline-flex px-3 py-1 rounded-full text-xs font-bold bg-primary/10 text-primary uppercase tracking-widest border border-primary/20">Discovery Portal</span>
            <h1 class="text-3xl md:text-5xl font-extrabold font-heading text-text-primary">Popular Destinations</h1>
            <p class="text-text-secondary max-w-lg mx-auto text-sm">Explore high-quality, verified student PGs and co-living hubs positioned near premium landmark coordinates.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-start animate-fade-in-up">
            <!-- Left Side: Image Gallery -->
            <div class="md:col-span-7 space-y-4">
                <div class="group relative overflow-hidden rounded-2xl shadow-xl border border-border-color bg-bg-card">
                    <img class="w-full h-[320px] object-cover group-hover:scale-105 transition-transform duration-500" src="<%= assetUrl('img/desitination-1.jpg') %>" alt="Amritsar Golden Temple">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                    <div class="absolute bottom-6 left-6 text-white space-y-1">
                        <span class="inline-block bg-primary text-white text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-lg mb-1">Featured Location</span>
                        <h2 class="text-2xl font-extrabold font-heading">Amritsar, Punjab</h2>
                        <p class="text-xs opacity-90 font-medium">Home to the divine Golden Temple</p>
                    </div>
                </div>
            </div>

            <!-- Right Side: Details / Travel Info -->
            <div class="md:col-span-5 glass-panel rounded-2xl p-6 md:p-8 space-y-6 border border-border-color">
                <div class="space-y-2">
                    <h2 class="text-2xl font-extrabold font-heading text-primary">Golden Temple</h2>
                    <p class="text-xs md:text-sm text-text-secondary leading-relaxed font-body">
                        The Golden Temple in Amritsar, Punjab, is a must-visit destination for anyone interested in spirituality, history, and culture. Plan your booking slots near this spiritual sanctuary.
                    </p>
                </div>

                <!-- Highlights List -->
                <div class="space-y-4">
                    <h5 class="text-xs font-bold text-text-secondary uppercase tracking-widest border-b border-border-color pb-1.5">Highlights</h5>
                    <ul class="space-y-2.5 text-xs md:text-sm text-text-secondary">
                        <li class="flex items-start gap-2.5">
                            <i class="fa-solid fa-circle-check text-primary mt-0.5"></i>
                            <span><strong>Historical Significance:</strong> Founded by Guru Ram Das in 1577 and completed by Guru Arjan in 1604.</span>
                        </li>
                        <li class="flex items-start gap-2.5">
                            <i class="fa-solid fa-circle-check text-primary mt-0.5"></i>
                            <span><strong>Architecture:</strong> Renowned for its stunning gold leaf and clean marble reflections.</span>
                        </li>
                        <li class="flex items-start gap-2.5">
                            <i class="fa-solid fa-circle-check text-primary mt-0.5"></i>
                            <span><strong>Langar:</strong> Hosts one of the world's largest free community kitchens, serving thousands daily.</span>
                        </li>
                        <li class="flex items-start gap-2.5">
                            <i class="fa-solid fa-circle-check text-primary mt-0.5"></i>
                            <span><strong>Symbol of Equality:</strong> Entrances on all four sides symbolize absolute openness to all people.</span>
                        </li>
                    </ul>
                </div>

                <!-- Tips List -->
                <div class="space-y-4 pt-2">
                    <h5 class="text-xs font-bold text-text-secondary uppercase tracking-widest border-b border-border-color pb-1.5">Tips for Visitors</h5>
                    <ul class="space-y-2 text-xs text-text-secondary font-medium">
                        <li class="flex items-center gap-2">
                            <i class="fa-solid fa-circle-info text-secondary"></i>
                            <span>Dress Modestly: Cover shoulders/knees. Head coverings required.</span>
                        </li>
                        <li class="flex items-center gap-2">
                            <i class="fa-solid fa-circle-info text-secondary"></i>
                            <span>Remove Shoes: Free shoe-drop counters are available at gate.</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <%- include('footer') %>
</body>

</html>