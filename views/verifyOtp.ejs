<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify OTP - FMPG</title>
    <!-- Include central Tailwind Configuration -->
    <%- include('tailwind-head') %>
</head>

<body class="bg-bg-body text-text-primary transition-colors duration-300 min-h-screen flex items-center justify-center py-12 px-6 relative overflow-hidden">
    
    <!-- Background glowing dynamic blob ornaments -->
    <div class="absolute top-[-10%] left-[-10%] h-96 w-96 rounded-full bg-primary/10 blur-3xl z-0"></div>
    <div class="absolute bottom-[-10%] right-[-10%] h-96 w-96 rounded-full bg-secondary/10 blur-3xl z-0"></div>

    <div class="w-full max-w-md z-10 animate-fade-in-up">
        <!-- Logo Header -->
        <div class="flex flex-col items-center gap-3 mb-8">
            <a href="/" class="flex items-center gap-3">
                <img src="<%= assetUrl('img/logo.png') %>" alt="FMPG Logo" class="h-12 w-auto">
                <span class="font-heading text-3xl font-extrabold text-text-primary tracking-tight">FM<span class="text-primary">PG</span></span>
            </a>
        </div>

        <!-- Glassmorphic Reset Panel -->
        <div class="glass-panel p-8 rounded-3xl bg-bg-card border-border-color shadow-2xl flex flex-col gap-6">
            <h2 class="font-heading text-2xl font-black text-center text-text-primary">Verify Verification Code</h2>
            <p class="text-xs font-semibold text-text-secondary text-center">We've sent a 6-digit verification code to your email. Enter the code and your new password below.</p>

            <form action="/forgot/verify-otp" method="POST" class="flex flex-col gap-5">
                <input type="hidden" name="email" value="<%= email %>">

                <!-- OTP Input -->
                <div class="flex flex-col gap-1.5">
                    <label for="otp" class="text-xs font-bold text-text-secondary uppercase tracking-wider">Verification OTP</label>
                    <div class="relative flex items-center">
                        <i class="fas fa-key absolute left-4 text-text-secondary text-sm"></i>
                        <input type="text" id="otp" name="otp" class="w-full bg-bg-body border border-border-color rounded-2xl py-3.5 pl-11 pr-4 text-sm font-semibold focus:outline-none focus:border-primary text-text-primary transition-colors" placeholder="6-digit code" required>
                    </div>
                </div>

                <!-- New Password Input -->
                <div class="flex flex-col gap-1.5">
                    <label for="newPassword" class="text-xs font-bold text-text-secondary uppercase tracking-wider">New Password</label>
                    <div class="relative flex items-center">
                        <i class="fas fa-lock absolute left-4 text-text-secondary text-sm"></i>
                        <input type="password" id="newPassword" name="newPassword" class="w-full bg-bg-body border border-border-color rounded-2xl py-3.5 pl-11 pr-4 text-sm font-semibold focus:outline-none focus:border-primary text-text-primary transition-colors" placeholder="••••••••" required>
                    </div>
                </div>

                <button type="submit" class="w-full py-4 bg-primary hover:bg-primary-hover text-white font-bold rounded-2xl shadow-lg shadow-primary/20 hover:scale-[1.01] transition-all cursor-pointer mt-2 text-base">
                    Reset Password
                </button>
                
                <h4 class="text-xs text-text-secondary text-center font-bold">
                    Didn't receive code? <a href="/forgot" class="text-primary hover:underline">Request OTP Again</a>
                </h4>
            </form>
        </div>
    </div>
</body>

</html>
