<%- include('partials/header') %>

<div class="p-6 space-y-6 animate-fade-in-up">
  <!-- Title & Description Header -->
  <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-border-color pb-4">
    <div>
      <h1 class="text-3xl font-extrabold font-heading text-primary">System Analytics & Insights</h1>
      <p class="text-text-secondary text-sm mt-1">Interactive data visualizations detailing booking timelines, property distributions, and user trends.</p>
    </div>
    <div class="flex items-center gap-2 bg-primary/10 text-primary border border-primary/20 rounded-xl px-4 py-2 text-xs font-semibold self-start md:self-auto">
      <i class="fa-solid fa-chart-pie animate-pulse"></i> Data Analytics Center
    </div>
  </div>

  <!-- Primary Analytics Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    
    <!-- Chart 1: Line Chart (Bookings Over Time) -->
    <div class="glass-panel rounded-2xl p-6 border border-border-color shadow-lg space-y-3">
      <h3 class="font-heading font-extrabold text-base text-primary flex items-center gap-2">
        <i class="fa-solid fa-chart-line"></i> Bookings Over Time
      </h3>
      <div class="pt-2">
        <canvas id="lineChart" class="max-h-[260px]"></canvas>
      </div>
    </div>

    <!-- Chart 2: Bar Chart (Bookings Per Property) -->
    <div class="glass-panel rounded-2xl p-6 border border-border-color shadow-lg space-y-3">
      <h3 class="font-heading font-extrabold text-base text-primary flex items-center gap-2">
        <i class="fa-solid fa-chart-bar"></i> Bookings Per Property
      </h3>
      <div class="pt-2">
        <canvas id="barChart" class="max-h-[260px]"></canvas>
      </div>
    </div>

    <!-- Chart 3: Area Chart (Booking Status Breakdown) -->
    <div class="glass-panel rounded-2xl p-6 border border-border-color shadow-lg space-y-3">
      <h3 class="font-heading font-extrabold text-base text-primary flex items-center gap-2">
        <i class="fa-solid fa-chart-area"></i> Booking Status Breakdown
      </h3>
      <div class="pt-2">
        <canvas id="areaChart" class="max-h-[260px]"></canvas>
      </div>
    </div>

    <!-- Chart 4: Doughnut Chart (Property Types Breakdown) -->
    <div class="glass-panel rounded-2xl p-6 border border-border-color shadow-lg space-y-3">
      <h3 class="font-heading font-extrabold text-base text-primary flex items-center gap-2">
        <i class="fa-solid fa-circle-dot"></i> Property Types Breakdown
      </h3>
      <div class="pt-2">
        <canvas id="doughnutChart" class="max-h-[260px]"></canvas>
      </div>
    </div>

    <!-- Chart 5: Pie Chart (User Gender Distribution) -->
    <div class="glass-panel rounded-2xl p-6 border border-border-color shadow-lg space-y-3">
      <h3 class="font-heading font-extrabold text-base text-primary flex items-center gap-2">
        <i class="fa-solid fa-venus-mars"></i> User Gender Distribution
      </h3>
      <div class="pt-2">
        <canvas id="pieChart" class="max-h-[260px]"></canvas>
      </div>
    </div>

    <!-- Chart 6: Scatter Chart (Active Bookings) -->
    <div class="glass-panel rounded-2xl p-6 border border-border-color shadow-lg space-y-3">
      <h3 class="font-heading font-extrabold text-base text-primary flex items-center gap-2">
        <i class="fa-solid fa-chart-scatter"></i> Active Bookings Distribution
      </h3>
      <div class="pt-2">
        <canvas id="scatterChart" class="max-h-[260px]"></canvas>
      </div>
    </div>

    <!-- Chart 7: Bookings by Property Type -->
    <div class="glass-panel rounded-2xl p-6 border border-border-color shadow-lg space-y-3 md:col-span-2">
      <h3 class="font-heading font-extrabold text-base text-primary flex items-center gap-2">
        <i class="fa-solid fa-house-chimney-window"></i> Bookings by Property Type
      </h3>
      <div class="pt-2 max-w-md mx-auto">
        <canvas id="bookingsByPropertyTypeChart" class="max-h-[260px]"></canvas>
      </div>
    </div>

  </div>
</div>

<!-- Close Sidebar & Main wrappers opened in partials/header -->
      </div>
   </div>

<!-- vendor scripts -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@2.9.4/dist/Chart.min.js"></script>

<!-- Charts Data Bindings & Initializers -->
<script>
  // Data from backend EJS
  const bookingsOverTime = <%- JSON.stringify(bookingsOverTime) %>;
  const bookingsPerProperty = <%- JSON.stringify(bookingsPerProperty) %>;
  const bookingsByPropertyType = <%- JSON.stringify(bookingsByPropertyType) %>;

  const confirmedBookings = <%= confirmedBookings %>;
  const pendingBookings = <%= pendingBookings %>;
  const cancelledBookings = <%= cancelledBookings %>;
  const totalBookings = <%= totalBookings %>;
  const pgProperties = <%= pgProperties %>;
  const hostelProperties = <%= hostelProperties %>;
  const flatProperties = <%= flatProperties %>;
  const pgWithMessProperties = <%= pgWithMessProperties %>;
  const maleProperties = <%= maleProperties %>;
  const femaleProperties = <%= femaleProperties %>;
  const activeBookings = <%= activeBookings %>;

  // Chart Global configurations
  Chart.defaults.global.defaultFontFamily = "'Inter', sans-serif";
  Chart.defaults.global.legend.labels.usePointStyle = true;
  Chart.defaults.global.legend.position = 'bottom';

  // 1. Line Chart
  new Chart(document.getElementById('lineChart').getContext('2d'), {
    type: 'line',
    data: {
      labels: bookingsOverTime.map(item => item._id),
      datasets: [{
        label: 'Bookings Count',
        data: bookingsOverTime.map(item => item.count),
        backgroundColor: 'rgba(16, 185, 129, 0.1)',
        borderColor: '#10b981',
        borderWidth: 2.5,
        pointBackgroundColor: '#10b981',
        pointRadius: 4,
        tension: 0.3
      }]
    },
    options: {
      responsive: true,
      scales: {
        yAxes: [{ gridLines: { color: 'rgba(0,0,0,0.05)' } }],
        xAxes: [{ gridLines: { display: false } }]
      }
    }
  });

  // 2. Bar Chart
  new Chart(document.getElementById('barChart').getContext('2d'), {
    type: 'bar',
    data: {
      labels: bookingsPerProperty.map(item => item.propertyName),
      datasets: [{
        label: 'Total Bookings',
        data: bookingsPerProperty.map(item => item.total),
        backgroundColor: 'rgba(59, 130, 246, 0.15)',
        borderColor: '#3b82f6',
        borderWidth: 2,
        borderRadius: 8
      }]
    },
    options: {
      responsive: true,
      scales: {
        yAxes: [{ gridLines: { color: 'rgba(0,0,0,0.05)' } }]
      }
    }
  });

  // 3. Area Chart
  new Chart(document.getElementById('areaChart').getContext('2d'), {
    type: 'line',
    data: {
      labels: ['Confirmed', 'Pending', 'Cancelled'],
      datasets: [{
        label: 'Bookings',
        data: [confirmedBookings, pendingBookings, cancelledBookings],
        backgroundColor: 'rgba(245, 158, 11, 0.15)',
        borderColor: '#f59e0b',
        borderWidth: 2.5,
        fill: true
      }]
    },
    options: {
      responsive: true
    }
  });

  // 4. Doughnut Chart
  new Chart(document.getElementById('doughnutChart').getContext('2d'), {
    type: 'doughnut',
    data: {
      labels: ['PG', 'Hostel', 'Flat', 'PG with Mess'],
      datasets: [{
        data: [pgProperties, hostelProperties, flatProperties, pgWithMessProperties],
        backgroundColor: ['#10b981', '#3b82f6', '#f59e0b', '#8b5cf6'],
        borderWidth: 0
      }]
    },
    options: {
      responsive: true,
      cutoutPercentage: 70
    }
  });

  // 5. Pie Chart
  new Chart(document.getElementById('pieChart').getContext('2d'), {
    type: 'pie',
    data: {
      labels: ['Male Only', 'Female Only'],
      datasets: [{
        data: [maleProperties, femaleProperties],
        backgroundColor: ['#3b82f6', '#ec4899'],
        borderWidth: 0
      }]
    },
    options: {
      responsive: true
    }
  });

  // 6. Scatter Chart
  new Chart(document.getElementById('scatterChart').getContext('2d'), {
    type: 'scatter',
    data: {
      datasets: [{
        label: 'Active Bookings Distribution',
        data: [{ x: 1, y: activeBookings }],
        backgroundColor: '#10b981',
        pointRadius: 8
      }]
    },
    options: {
      responsive: true
    }
  });

  // 7. Bookings by Property Type
  new Chart(document.getElementById('bookingsByPropertyTypeChart').getContext('2d'), {
    type: 'doughnut',
    data: {
      labels: bookingsByPropertyType.map(item => item._id),
      datasets: [{
        data: bookingsByPropertyType.map(item => item.count),
        backgroundColor: ['#10b981', '#3b82f6', '#f59e0b', '#8b5cf6'],
        borderWidth: 0
      }]
    },
    options: {
      responsive: true,
      cutoutPercentage: 70
    }
  });
</script>
</body>
</html>
