<%- include('partials/header') %>

<% const formatCurrency = (value) => new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 }).format(value || 0); %>
<div class="p-6 space-y-6 animate-fade-in-up">
  <!-- Title / Workspace Header -->
  <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-border-color pb-4">
    <div>
      <h1 class="text-3xl font-extrabold font-heading text-primary">Admin Overview Dashboard</h1>
      <p class="text-text-secondary text-sm mt-1">Real-time analytical graphs, rental transactions, location metrics, and traffic rates.</p>
    </div>
    <div class="flex items-center gap-2 bg-primary/10 text-primary border border-primary/20 rounded-xl px-4 py-2 text-xs font-semibold self-start md:self-auto">
      <span class="w-2 h-2 rounded-full bg-primary animate-ping"></span> Live System Telemetry
    </div>
  </div>

  <!-- Row 1: Fast Stats Widgets -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
    <!-- Stat 1: Revenue -->
    <div class="glass-panel rounded-2xl p-6 border border-border-color shadow-lg relative overflow-hidden group">
      <div class="absolute -top-6 -right-6 w-20 h-20 bg-emerald-500/5 group-hover:bg-emerald-500/10 rounded-full blur-xl transition-all duration-300"></div>
      <div class="space-y-2">
        <span class="block text-[10px] font-bold uppercase tracking-wider text-text-secondary">Gross Revenue</span>
        <h2 class="text-3xl font-extrabold text-primary font-heading"><%= formatCurrency(summaryStats.totalRevenue) %></h2>
        <div class="flex items-center gap-1.5 text-xs text-emerald-500 font-semibold pt-1">
          <i class="fa-solid fa-sack-dollar"></i> <span class="text-text-secondary font-normal">from payments</span>
        </div>
      </div>
    </div>

    <!-- Stat 2: Annual Profit -->
    <div class="glass-panel rounded-2xl p-6 border border-border-color shadow-lg relative overflow-hidden group">
      <div class="absolute -top-6 -right-6 w-20 h-20 bg-amber-500/5 group-hover:bg-amber-500/10 rounded-full blur-xl transition-all duration-300"></div>
      <div class="space-y-2">
        <span class="block text-[10px] font-bold uppercase tracking-wider text-text-secondary">Total Bookings</span>
        <h2 class="text-3xl font-extrabold text-amber-500 font-heading"><%= summaryStats.totalBookings %></h2>
        <div class="flex items-center gap-1.5 text-xs text-amber-500 font-semibold pt-1">
          <i class="fa-solid fa-calendar-check"></i> <span class="text-text-secondary font-normal">all-time</span>
        </div>
      </div>
    </div>

    <!-- Stat 3: Total Impressions -->
    <div class="glass-panel rounded-2xl p-6 border border-border-color shadow-lg relative overflow-hidden group">
      <div class="absolute -top-6 -right-6 w-20 h-20 bg-blue-500/5 group-hover:bg-blue-500/10 rounded-full blur-xl transition-all duration-300"></div>
      <div class="space-y-2">
        <span class="block text-[10px] font-bold uppercase tracking-wider text-text-secondary">Total Users</span>
        <h2 class="text-3xl font-extrabold text-blue-500 font-heading"><%= summaryStats.totalUsers %></h2>
        <div class="flex items-center gap-1.5 text-xs text-blue-500 font-semibold pt-1">
          <i class="fa-solid fa-users"></i> <span class="text-text-secondary font-normal">registered</span>
        </div>
      </div>
    </div>

    <!-- Stat 4: Traffic conversions -->
    <div class="glass-panel rounded-2xl p-6 border border-border-color shadow-lg relative overflow-hidden group">
      <div class="absolute -top-6 -right-6 w-20 h-20 bg-purple-500/5 group-hover:bg-purple-500/10 rounded-full blur-xl transition-all duration-300"></div>
      <div class="space-y-2">
        <span class="block text-[10px] font-bold uppercase tracking-wider text-text-secondary">Active Bookings</span>
        <h2 class="text-3xl font-extrabold text-purple-500 font-heading"><%= summaryStats.activeBookings %></h2>
        <div class="flex items-center gap-1.5 text-xs text-purple-500 font-semibold pt-1">
          <i class="fa-solid fa-chart-line"></i> <span class="text-text-secondary font-normal">in progress</span>
        </div>
      </div>
    </div>
  </div>



  <!-- Row 4: Timeline & Order Stats -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <!-- Big analytics chart -->
    <div class="glass-panel rounded-2xl p-6 border border-border-color shadow-lg md:col-span-2 space-y-4">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-3 border-b border-border-color pb-3">
        <div>
          <h3 class="font-heading font-extrabold text-base text-primary flex items-center gap-2">
            <i class="fa-solid fa-chart-line"></i> Booking Performance Timeline
          </h3>
          <span class="text-xs text-text-secondary font-medium">Sales performance revenue based by metrics</span>
        </div>
        
        <!-- Weeks / Months switcher EJS compatible buttons -->
        <div class="flex bg-bg-body border border-border-color rounded-xl p-1 text-xs">
          <button class="px-3 py-1.5 rounded-lg bg-primary text-white font-semibold">1W</button>
          <button class="px-3 py-1.5 rounded-lg text-text-secondary hover:text-primary transition-colors">1M</button>
          <button class="px-3 py-1.5 rounded-lg text-text-secondary hover:text-primary transition-colors">3M</button>
          <button class="px-3 py-1.5 rounded-lg text-text-secondary hover:text-primary transition-colors">1Y</button>
        </div>
      </div>
      
      <div class="chart-container pt-3">
        <canvas id="revenue-chart" height="200"></canvas>
      </div>
    </div>

    <!-- Order Stats chart -->
    <div class="glass-panel rounded-2xl p-6 border border-border-color shadow-lg space-y-4">
      <div class="border-b border-border-color pb-3">
        <h3 class="font-heading font-extrabold text-base text-primary flex items-center gap-2">
          <i class="fa-solid fa-chart-pie"></i> Order Statistics
        </h3>
        <span class="text-xs text-text-secondary font-medium">Distribution by category</span>
      </div>
      
      <div class="chart-container pt-3 relative">
        <canvas id="chart-sales" height="200"></canvas>
      </div>
      
      <div id="sales-legend" class="flex flex-wrap gap-2 text-xs font-semibold justify-center"></div>
    </div>
  </div>
</div>

<!-- Close Sidebar & Main wrappers opened in partials/header -->
      </div>
   </div>

<!-- vendor scripts -->
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@2.9.4/dist/Chart.min.js"></script>
<script>
  window.dashboardData = <%- JSON.stringify(dashboardData || {}) %>;
</script>
<script src="<%= assetUrl('assets/js/dashboard.js') %>?v=<%= Date.now() %>"></script>
</body>
</html>