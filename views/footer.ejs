<!-- Back to Top Control -->
<button id="back-to-top-btn" class="fixed right-6 bottom-6 z-[99] h-12 w-12 rounded-full bg-primary text-white flex items-center justify-center shadow-lg hover:bg-primary-hover hover:scale-105 transition-premium scale-0 opacity-0 cursor-pointer" aria-label="Back to Top" style="box-shadow: 0 8px 24px rgba(5, 150, 105, 0.25)">
    <i class="bi bi-arrow-up text-xl"></i>
</button>

<!-- JavaScript Libraries -->
<script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>

<script>
    (function() {
        const topBtn = document.getElementById('back-to-top-btn');
        
        // Show/hide Back to Top button
        window.addEventListener('scroll', () => {
            if (window.scrollY > 300) {
                topBtn.classList.remove('scale-0', 'opacity-0');
                topBtn.classList.add('scale-100', 'opacity-100');
            } else {
                topBtn.classList.remove('scale-100', 'opacity-100');
                topBtn.classList.add('scale-0', 'opacity-0');
            }
        });

        // Click interaction
        if (topBtn) {
            topBtn.addEventListener('click', (e) => {
                e.preventDefault();
                window.scrollTo({
                    top: 0,
                    behavior: 'smooth'
                });
            });
        }
    })();
</script>