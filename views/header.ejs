<!-- Spinner Loader Start -->
<div id="spinner" class="fixed inset-0 z-[99999] flex items-center justify-center bg-bg-body transition-all duration-500 opacity-100 visible">
    <div class="relative flex items-center justify-center">
        <!-- Inner glowing ring -->
        <div class="h-16 w-16 animate-spin rounded-full border-4 border-solid border-primary border-t-transparent"></div>
        <!-- Center core pulse -->
        <div class="absolute h-6 w-6 animate-pulse rounded-full bg-secondary animate-ping"></div>
    </div>
</div>
<script>
    (document.ready || function () {
        function hideSpinner() {
            var spinner = document.getElementById('spinner');
            if (!spinner) return;
            spinner.classList.add('opacity-0', 'invisible');
            setTimeout(() => {
                spinner.style.display = 'none';
            }, 500);
        }
        window.addEventListener('load', hideSpinner);
        setTimeout(hideSpinner, 1500); // reduced timeout for snappier experience
    })();
</script>
<!-- Spinner Loader End -->

