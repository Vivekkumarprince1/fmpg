<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>About Us - FMPG</title>
    <!-- Include central Tailwind Configuration -->
    <%- include('tailwind-head') %>
</head>

<body class="bg-bg-body text-text-primary transition-colors duration-300">

    <!-- Header Start -->
    <%- include('header') %>
    <!-- Header End -->

    <!-- About Section Start -->
    <section class="py-20 max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center animate-fade-in-up">
            <!-- About Image with floating stats -->
            <div class="relative rounded-3xl overflow-hidden shadow-2xl aspect-[4/3] group">
                <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="<%= assetUrl('img/about.jpg') %>" alt="Comfortable Room Living">
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950/60 to-transparent"></div>
                <!-- Mini floating stat banner -->
                <div class="absolute bottom-6 left-6 right-6 p-6 rounded-2xl bg-white/10 backdrop-blur-md border border-white/20 text-white flex items-center justify-between">
                    <div>
                        <span class="text-2xl font-extrabold text-primary">100%</span>
                        <p class="text-xs text-slate-300 font-semibold">Verified PGs</p>
                    </div>
                    <div class="h-8 w-[1px] bg-white/20"></div>
                    <div>
                        <span class="text-2xl font-extrabold text-secondary">24/7</span>
                        <p class="text-xs text-slate-300 font-semibold">Live Support</p>
                    </div>
                </div>
            </div>

            <!-- About Text -->
            <div class="flex flex-col gap-6 items-start">
                <div class="flex flex-col gap-2">
                    <span class="text-primary font-bold text-sm tracking-widest uppercase">About Us</span>
                    <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-black text-text-primary tracking-tight">
                        Welcome to <span class="text-primary">FMPG</span>
                    </h2>
                </div>
                
                <p class="text-text-secondary leading-relaxed text-base font-medium">
                    FMPG is your premier choice for hassle-free and comfortable hostel/PG living! We pride ourselves on creating a home away from home, offering you a perfect blend of modern convenience, tight security, and inclusive community.
                </p>
                <p class="text-text-secondary leading-relaxed text-base">
                    Our single and shared rooms are thoughtfully designed to offer you maximum comfort and privacy. Each property is handpicked and fully furnished with snug beds, wardrobes, study desks, high-speed WiFi, air conditioning, and hygiene-assured bathrooms.
                </p>

                <!-- Checkmarks Grid -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 w-full mt-2">
                    <div class="flex items-center gap-3">
                        <div class="h-6 w-6 rounded-full bg-primary/10 text-primary flex items-center justify-center text-xs">
                            <i class="fa fa-check"></i>
                        </div>
                        <span class="text-sm font-semibold text-text-primary">Handpicked Verified PGs</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="h-6 w-6 rounded-full bg-primary/10 text-primary flex items-center justify-center text-xs">
                            <i class="fa fa-check"></i>
                        </div>
                        <span class="text-sm font-semibold text-text-primary">Instant Online Payouts</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="h-6 w-6 rounded-full bg-primary/10 text-primary flex items-center justify-center text-xs">
                            <i class="fa fa-check"></i>
                        </div>
                        <span class="text-sm font-semibold text-text-primary">24/7 Direct Help Desk</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="h-6 w-6 rounded-full bg-primary/10 text-primary flex items-center justify-center text-xs">
                            <i class="fa fa-check"></i>
                        </div>
                        <span class="text-sm font-semibold text-text-primary">Zero Hidden Fees</span>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- About Section End -->

    <!-- Team Section Start -->
    <section class="py-20 bg-slate-50 dark:bg-slate-900/40 border-y border-border-color transition-colors duration-300">
        <div class="max-w-7xl mx-auto px-6 flex flex-col gap-12 text-center">
            <div class="flex flex-col gap-2">
                <span class="text-primary font-bold text-sm tracking-widest uppercase">Team</span>
                <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-black text-text-primary tracking-tight">Meet Our Team</h2>
            </div>

            <!-- Team Grid -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Member 1: Vivek -->
                <div class="glass-panel rounded-3xl overflow-hidden shadow-xl hover:scale-[1.02] transition-premium flex flex-col group">
                    <div class="relative overflow-hidden aspect-[4/3]">
                        <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="<%= assetUrl('img/team-1.jpg') %>" alt="Vivek Kumar">
                        <!-- Floating social triggers -->
                        <div class="absolute inset-0 bg-slate-950/40 flex items-center justify-center gap-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                            <a class="h-10 w-10 rounded-full bg-white hover:bg-primary hover:text-white text-slate-800 flex items-center justify-center shadow-lg transition-all hover:scale-105" href="https://x.com/Vivekra90835697" target="_blank"><i class="fab fa-twitter"></i></a>
                            <a class="h-10 w-10 rounded-full bg-white hover:bg-primary hover:text-white text-slate-800 flex items-center justify-center shadow-lg transition-all hover:scale-105" href="https://www.instagram.com/ideal_vivek_/" target="_blank"><i class="fab fa-instagram"></i></a>
                        </div>
                    </div>
                    <div class="p-6 text-center">
                        <h5 class="font-heading text-xl font-bold text-text-primary">Vivek Kumar</h5>
                        <p class="text-sm font-semibold text-primary uppercase tracking-wider mt-1">Founder & CEO</p>
                    </div>
                </div>

                <!-- Member 2: Vikas -->
                <div class="glass-panel rounded-3xl overflow-hidden shadow-xl hover:scale-[1.02] transition-premium flex flex-col group">
                    <div class="relative overflow-hidden aspect-[4/3]">
                        <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="<%= assetUrl('img/team-2.jpg') %>" alt="Vikas Adhikari">
                        <!-- Floating social triggers -->
                        <div class="absolute inset-0 bg-slate-950/40 flex items-center justify-center gap-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                            <a class="h-10 w-10 rounded-full bg-white hover:bg-primary hover:text-white text-slate-800 flex items-center justify-center shadow-lg transition-all hover:scale-105" href="https://www.linkedin.com/in/vikas-adhikari-646a0128b/" target="_blank"><i class="fab fa-linkedin-in"></i></a>
                            <a class="h-10 w-10 rounded-full bg-white hover:bg-primary hover:text-white text-slate-800 flex items-center justify-center shadow-lg transition-all hover:scale-105" href="https://x.com/vikas11652166" target="_blank"><i class="fab fa-twitter"></i></a>
                            <a class="h-10 w-10 rounded-full bg-white hover:bg-primary hover:text-white text-slate-800 flex items-center justify-center shadow-lg transition-all hover:scale-105" href="https://www.instagram.com/vikasadhikari9310/" target="_blank"><i class="fab fa-instagram"></i></a>
                        </div>
                    </div>
                    <div class="p-6 text-center">
                        <h5 class="font-heading text-xl font-bold text-text-primary">Vikas Adhikari</h5>
                        <p class="text-sm font-semibold text-primary uppercase tracking-wider mt-1">Co-Founder</p>
                    </div>
                </div>

                <!-- Member 3: Adarsh -->
                <div class="glass-panel rounded-3xl overflow-hidden shadow-xl hover:scale-[1.02] transition-premium flex flex-col group">
                    <div class="relative overflow-hidden aspect-[4/3]">
                        <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="<%= assetUrl('img/team-3.jpg') %>" alt="Adarsh Kumar Panday">
                        <!-- Floating social triggers -->
                        <div class="absolute inset-0 bg-slate-950/40 flex items-center justify-center gap-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                            <a class="h-10 w-10 rounded-full bg-white hover:bg-primary hover:text-white text-slate-800 flex items-center justify-center shadow-lg transition-all hover:scale-105" href="https://tr.ee/w-AV6iY65c" target="_blank"><i class="fab fa-linkedin-in"></i></a>
                            <a class="h-10 w-10 rounded-full bg-white hover:bg-primary hover:text-white text-slate-800 flex items-center justify-center shadow-lg transition-all hover:scale-105" href="https://tr.ee/Z5812sVo3z" target="_blank"><i class="fab fa-twitter"></i></a>
                            <a class="h-10 w-10 rounded-full bg-white hover:bg-primary hover:text-white text-slate-800 flex items-center justify-center shadow-lg transition-all hover:scale-105" href="https://tr.ee/_z_ePJyZDI" target="_blank"><i class="fab fa-instagram"></i></a>
                        </div>
                    </div>
                    <div class="p-6 text-center">
                        <h5 class="font-heading text-xl font-bold text-text-primary">Adarsh Kumar Panday</h5>
                        <p class="text-sm font-semibold text-primary uppercase tracking-wider mt-1">Co-Founder & CMO</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- Team Section End -->

    <!-- Footer Start -->
    <%- include('footer') %>
    <!-- Footer End -->

    <!-- Main JavaScript -->
    <script src="js/main.js"></script>
</body>

</html>