<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
    <meta charset="utf-8">
    <title>Refer & Earn Rewards - FMPG</title>
    <link rel="icon" href="/img/logo.png" type="image/icon type">
    
    <!-- Central Tailwind CSS & Theme Config -->
    <%- include('tailwind-head') %>
</head>

<body class="bg-bg-body text-text-primary min-h-screen flex flex-col transition-colors duration-300">
    <!-- Header -->
    <%- include('header') %>

    <!-- Referral Hero Block -->
    <section class="py-12 md:py-16 bg-gradient-to-b from-primary/5 to-transparent text-center px-4">
        <div class="max-w-3xl mx-auto space-y-4 animate-fade-in-up">
            <span class="inline-flex px-3 py-1 rounded-full text-xs font-bold bg-primary/10 text-primary uppercase tracking-widest border border-primary/20">Referral Program</span>
            <h1 class="text-3xl md:text-5xl font-extrabold font-heading text-text-primary">Refer Friends & Earn Credits</h1>
            <p class="text-text-secondary text-sm md:text-base max-w-xl mx-auto">Invite your friends to Find My PG. You will receive 100 account credits, and your friend gets 50 credits instantly upon signup!</p>
        </div>
    </section>

    <!-- Main Workspace -->
    <main class="flex-grow max-w-5xl mx-auto w-full px-6 pb-16 space-y-12">
        
        <!-- Referral Metrics Card -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch animate-fade-in-up">
            <!-- Credits Left Card -->
            <div class="glass-panel rounded-2xl p-6 border border-border-color shadow-lg flex flex-col justify-between items-center text-center">
                <div class="w-12 h-12 bg-primary/10 text-primary rounded-full flex items-center justify-center mb-4">
                    <i class="fa-solid fa-coins text-xl"></i>
                </div>
                <div class="space-y-1.5">
                    <span class="block text-[10px] uppercase font-bold text-text-secondary tracking-widest">Total Referral Credits</span>
                    <h2 class="text-4xl font-black text-primary font-heading"><%= user.referralCredits %></h2>
                </div>
                <span class="text-[10px] text-text-secondary font-semibold mt-3">1 credit = ₹1 (deductible on rent)</span>
            </div>

            <!-- Link copy Card -->
            <div class="glass-panel rounded-2xl p-6 border border-border-color shadow-lg md:col-span-2 flex flex-col justify-between space-y-4">
                <div>
                    <h3 class="font-heading font-extrabold text-base text-text-primary">Your Unique Invite Link</h3>
                    <p class="text-xs text-text-secondary mt-1">Copy and share this referral url via social platforms or direct messages.</p>
                </div>
                
                <div class="flex flex-col sm:flex-row gap-3">
                    <input type="text" readonly value="<%= user.referralLink %>" id="referralLink" 
                      class="flex-grow bg-bg-body border border-border-color rounded-xl px-4 py-3 text-sm text-text-primary font-mono focus:outline-none focus:border-primary select-all">
                    
                    <button onclick="copyReferralLink()" class="bg-primary hover:bg-primary-hover text-white font-bold px-6 py-3 rounded-xl shadow-md shadow-primary/20 transition-all cursor-pointer">
                        Copy Link
                    </button>
                </div>

                <!-- Brand Shares -->
                <div class="space-y-2">
                    <span class="block text-[10px] uppercase font-bold text-text-secondary tracking-widest">Quick Share</span>
                    <div class="flex flex-wrap gap-2.5">
                        <!-- WhatsApp -->
                        <a href="https://api.whatsapp.com/send?text=Join%20our%20platform%20with%20this%20link:%20<%= user.referralLink %>" target="_blank"
                          class="inline-flex items-center gap-1.5 bg-emerald-500 hover:bg-emerald-600 text-white text-xs font-semibold px-4 py-2.5 rounded-xl transition-all">
                            <i class="fab fa-whatsapp"></i> WhatsApp
                        </a>
                        
                        <!-- Email -->
                        <a href="mailto:?subject=Join%20FMPG%20Room%20Booking&body=Join%20our%20platform%20using%20this%20referral%20link:%20<%= user.referralLink %>"
                          class="inline-flex items-center gap-1.5 bg-blue-500 hover:bg-blue-600 text-white text-xs font-semibold px-4 py-2.5 rounded-xl transition-all">
                            <i class="fa-solid fa-envelope"></i> Email
                        </a>

                        <!-- Facebook -->
                        <a href="https://www.facebook.com/sharer/sharer.php?u=<%= user.referralLink %>" target="_blank"
                          class="inline-flex items-center gap-1.5 bg-blue-700 hover:bg-blue-800 text-white text-xs font-semibold px-4 py-2.5 rounded-xl transition-all">
                            <i class="fab fa-facebook-f"></i> Facebook
                        </a>

                        <!-- Twitter -->
                        <a href="https://twitter.com/intent/tweet?text=Join%20our%20platform%20with%20this%20link:%20<%= user.referralLink %>" target="_blank"
                          class="inline-flex items-center gap-1.5 bg-sky-500 hover:bg-sky-600 text-white text-xs font-semibold px-4 py-2.5 rounded-xl transition-all">
                            <i class="fab fa-twitter"></i> Twitter
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Referral Information & Terms -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start animate-fade-in-up">
            <!-- Guidelines -->
            <div class="glass-panel rounded-2xl p-6 md:p-8 border border-border-color shadow-lg space-y-4 text-xs md:text-sm text-text-secondary leading-relaxed">
                <h3 class="font-heading font-extrabold text-base text-primary border-b border-border-color pb-1.5">Referral Guidelines</h3>
                <p>Welcome to our PG finding platform! We value your support and trust, and we’ve introduced a "Refer & Earn" program to reward you for sharing our platform with your friends.</p>
                
                <ul class="space-y-2">
                    <li class="flex gap-2"><i class="fa-solid fa-circle-check text-primary mt-0.5"></i><span><strong>User Eligibility:</strong> Available to all registered FMPG accounts.</span></li>
                    <li class="flex gap-2"><i class="fa-solid fa-circle-check text-primary mt-0.5"></i><span><strong>Referral Criteria:</strong> The referee must stay at the PG for a minimum of 3 months to validate credits.</span></li>
                    <li class="flex gap-2"><i class="fa-solid fa-circle-check text-primary mt-0.5"></i><span><strong>Account Rewards:</strong> Earned credits are loaded directly into your profile wallet after verification.</span></li>
                    <li class="flex gap-2"><i class="fa-solid fa-circle-check text-primary mt-0.5"></i><span><strong>Wallet Expiration:</strong> Account credits must be used within 12 months.</span></li>
                </ul>
            </div>

            <!-- FAQs -->
            <div class="glass-panel rounded-2xl p-6 md:p-8 border border-border-color shadow-lg space-y-4 text-xs md:text-sm text-text-secondary leading-relaxed">
                <h3 class="font-heading font-extrabold text-base text-primary border-b border-border-color pb-1.5">Program FAQ Overview</h3>
                
                <div class="space-y-3">
                    <div>
                        <strong class="block text-text-primary font-heading font-bold mb-0.5">How do I invite someone?</strong>
                        <span>Copy your custom URL bar above or tap any quick-share WhatsApp/Facebook button.</span>
                    </div>
                    <div>
                        <strong class="block text-text-primary font-heading font-bold mb-0.5">When do I receive rewards?</strong>
                        <span>After the referee has successfully booked and completed payment for at least 3 months.</span>
                    </div>
                    <div>
                        <strong class="block text-text-primary font-heading font-bold mb-0.5">Can I refer myself?</strong>
                        <span>No, self-referrals are strictly prohibited and will void all credits.</span>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <%- include('footer') %>

    <script>
        function copyReferralLink() {
            const link = document.getElementById("referralLink");
            link.select();
            document.execCommand("copy");
            alert("Referral link copied to clipboard");
        }
    </script>
</body>

</html>