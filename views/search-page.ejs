<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>FMPG - Search Accommodations</title>
    <!-- Include central Tailwind Configuration -->
    <%- include('tailwind-head') %>
</head>

<body class="bg-bg-body text-text-primary transition-colors duration-300">

    <!-- Header Start -->
    <%- include('header') %>
    <!-- Header End -->

    <main class="py-12 max-w-7xl mx-auto px-6 flex flex-col gap-8">
        
        <!-- Filters Toolbar Section -->
        <section class="glass-panel p-6 rounded-3xl bg-bg-card border-border-color shadow-md flex flex-col sm:flex-row items-center justify-between gap-4">
            <div class="flex items-center gap-3">
                <div class="h-10 w-10 rounded-xl bg-primary/10 text-primary flex items-center justify-center text-lg">
                    <i class="fa fa-filter"></i>
                </div>
                <h2 class="font-heading text-xl font-bold">Filter & Sort Accommodations</h2>
            </div>
            
            <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 w-full sm:w-auto">
                <!-- Gender Filter -->
                <div class="relative">
                    <select id="gender-filter" class="w-full sm:w-48 bg-bg-body border border-border-color rounded-2xl py-3 px-4 text-sm font-semibold focus:outline-none focus:border-primary text-text-primary transition-colors cursor-pointer appearance-none">
                        <option value="all">All Genders</option>
                        <option value="male">Male</option>
                        <option value="female">Female</option>
                        <option value="unisex">Unisex</option>
                    </select>
                    <i class="fa fa-chevron-down text-text-secondary text-xs absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none"></i>
                </div>
                
                <!-- Sorting Filter -->
                <div class="relative">
                    <select id="sorting-filter" class="w-full sm:w-48 bg-bg-body border border-border-color rounded-2xl py-3 px-4 text-sm font-semibold focus:outline-none focus:border-primary text-text-primary transition-colors cursor-pointer appearance-none">
                        <option value="relevant">Most Relevant</option>
                        <option value="low-to-high">Price: Low to High</option>
                        <option value="high-to-low">Price: High to Low</option>
                        <option value="distance">Distance (GPS)</option>
                    </select>
                    <i class="fa fa-chevron-down text-text-secondary text-xs absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none"></i>
                </div>
            </div>
        </section>

        <!-- Properties Grid List -->
        <section class="w-full">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="properties-list">
                <% properties.forEach(property => { %>
                <article class="glass-panel rounded-3xl overflow-hidden cursor-pointer hover:scale-[1.02] flex flex-col group transition-premium" onclick="readmore('<%= property._id %>')">
                    <!-- Media Gallery -->
                    <div class="relative overflow-hidden aspect-[4/3] w-full bg-slate-100">
                        <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" src="<%= assetUrl(property.images[0]) %>" alt="<%= property.propertyName %>">
                        <!-- Rating Badge -->
                        <span class="absolute top-4 right-4 inline-flex items-center gap-1 px-3 py-1 rounded-full bg-slate-900/60 backdrop-blur-md text-secondary font-bold text-xs">
                            <i class="fa fa-star"></i> 5.0
                        </span>
                        <!-- Type Accent Badge -->
                        <span class="absolute bottom-4 left-4 inline-flex px-3 py-1 rounded-full bg-primary text-white font-semibold text-xs tracking-wider uppercase">
                            <%= property.type %>
                        </span>
                    </div>

                    <!-- Room Specifications -->
                    <div class="flex border-b border-border-color text-text-secondary text-xs font-semibold">
                        <div class="flex-1 text-center py-3 border-r border-border-color">
                            <i class="fa fa-calendar-alt text-primary mr-1"></i> Per Month
                        </div>
                        <div class="flex-1 text-center py-3">
                            <i class="fa fa-user-friends text-primary mr-1"></i> Max Capacity: <%= property.capacity %>
                        </div>
                    </div>

                    <!-- Description/Pricing Info -->
                    <div class="p-6 flex-1 flex flex-col gap-4 justify-between">
                        <div class="flex flex-col gap-2">
                            <h3 class="font-heading text-xl font-bold group-hover:text-primary transition-colors text-text-primary line-clamp-1">
                                <%= property.propertyName %>
                            </h3>
                            
                            <div class="text-sm font-semibold text-text-secondary">
                                <% if (property.rooms && property.rooms.length > 0) { %>
                                    <span class="text-slate-500 font-medium">Starting Price:</span> <span class="text-primary font-bold text-base">₹<%= property.rooms[0] ? property.rooms[0].price : 'N/A' %></span>
                                <% } else { %>
                                    <span class="text-rose-500 font-medium"><i class="fa fa-info-circle mr-1"></i> No rooms available</span>
                                <% } %>
                            </div>
                        </div>

                        <!-- CTA Book Button -->
                        <div class="pt-4 border-t border-border-color flex justify-between items-center">
                            <span class="text-xs text-text-secondary font-semibold"><i class="fa-solid fa-shield text-emerald-500 mr-1"></i> Secure Deal</span>
                            <button class="px-6 py-2.5 bg-primary hover:bg-primary-hover text-white text-sm font-bold rounded-xl shadow-md shadow-primary/10 transition-colors cursor-pointer" onclick="event.stopPropagation(); readmore('<%= property._id %>')">
                                Book Now
                            </button>
                        </div>
                    </div>
                </article>
                <% }) %>
            </div>
        </section>
    </main>

    <!-- Footer Inclusion -->
    <%- include('footer') %>

    <!-- Template JavaScript -->
    <script src="js/main.js"></script>

    <!-- AJAX Filter and Distance Logic -->
    <script>
        const readmore = (propertyID) => {
            const queryString = `propertyID=${propertyID}`;
            window.location.href = `/readmore?${queryString}`;
        };
    </script>
    <script>
        document.getElementById('gender-filter').addEventListener('change', applyFilters);
        document.getElementById('sorting-filter').addEventListener('change', applyFilters);
    
        async function applyFilters() {
            const gender = document.getElementById('gender-filter').value;
            const sort = document.getElementById('sorting-filter').value;
    
            let queryParams = new URLSearchParams({ gender, sort });
    
            // If the user selected "Distance", request geolocation access
            if (sort === 'distance') {
                if (navigator.geolocation) {
                    navigator.geolocation.getCurrentPosition(async (position) => {
                        const lat = position.coords.latitude;
                        const lng = position.coords.longitude;
    
                        queryParams.append('lat', lat);
                        queryParams.append('lng', lng);
    
                        await fetchProperties(queryParams);
                    }, (error) => {
                        alert("Unable to retrieve your location for distance calculations.");
                        console.error(error);
                    });
                } else {
                    alert("Geolocation is not supported by this browser.");
                }
            } else {
                await fetchProperties(queryParams);
            }
        }
    
        // Fetch matching properties asynchronously without full reload
        async function fetchProperties(queryParams) {
            try {
                const response = await fetch(`/search-page?${queryParams.toString()}`);
                const data = await response.text();
    
                const parser = new DOMParser();
                const htmlDoc = parser.parseFromString(data, 'text/html');
                const propertiesList = htmlDoc.getElementById('properties-list').innerHTML;
    
                // Swap grid panel contents instantly
                document.getElementById('properties-list').innerHTML = propertiesList;
            } catch (error) {
                console.error("Error fetching properties via AJAX:", error);
            }
        }
    </script>
</body>

</html>