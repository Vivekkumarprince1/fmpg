<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>Book a Room - FMPG</title>
    <!-- Include central Tailwind Configuration -->
    <%- include('tailwind-head') %>
</head>

<body class="bg-bg-body text-text-primary transition-colors duration-300">

    <!-- Header Start -->
    <%- include('header') %>
    <!-- Header End -->

    <!-- Process Section Start -->
    <section class="py-16 max-w-7xl mx-auto px-6 flex flex-col gap-12">
        <div class="text-center flex flex-col gap-2">
            <span class="text-primary font-bold text-sm tracking-widest uppercase">Process</span>
            <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-black text-text-primary tracking-tight">3 Easy Steps</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 relative">
            <div class="hidden md:block absolute top-[4.5rem] left-[15%] right-[15%] h-[2px] bg-border-color z-0"></div>
            
            <div class="relative flex flex-col items-center gap-4 text-center z-10 group">
                <div class="h-20 w-20 rounded-full bg-primary text-white border-8 border-bg-body flex items-center justify-center text-2xl shadow-xl transition-all duration-300 group-hover:scale-110">
                    <i class="fa fa-globe"></i>
                </div>
                <h3 class="font-heading text-xl font-bold mt-2">1. Choose A Room</h3>
                <p class="text-sm text-text-secondary max-w-xs leading-relaxed font-medium">Browse verified listings, filter features, and select your ideal room setup.</p>
            </div>

            <div class="relative flex flex-col items-center gap-4 text-center z-10 group">
                <div class="h-20 w-20 rounded-full bg-primary text-white border-8 border-bg-body flex items-center justify-center text-2xl shadow-xl transition-all duration-300 group-hover:scale-110">
                    <i class="fa-solid fa-indian-rupee-sign"></i>
                </div>
                <h3 class="font-heading text-xl font-bold mt-2">2. Pay Securely</h3>
                <p class="text-sm text-text-secondary max-w-xs leading-relaxed font-medium">Verify rental inclusions, complete security payouts instantly via secure online UPI.</p>
            </div>

            <div class="relative flex flex-col items-center gap-4 text-center z-10 group">
                <div class="h-20 w-20 rounded-full bg-primary text-white border-8 border-bg-body flex items-center justify-center text-2xl shadow-xl transition-all duration-300 group-hover:scale-110">
                    <i class="fa-regular fa-building"></i>
                </div>
                <h3 class="font-heading text-xl font-bold mt-2">3. Move In Today</h3>
                <p class="text-sm text-text-secondary max-w-xs leading-relaxed font-medium">Collect your confirmation, check-in smoothly, and start hassle-free living!</p>
            </div>
        </div>
    </section>
    <!-- Process Section End -->

    <!-- Booking Form Section Start -->
    <main class="py-12 max-w-5xl mx-auto px-6">
        <div class="glass-panel p-8 md:p-12 rounded-3xl bg-bg-card border-border-color shadow-2xl">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
                
                <!-- Left Side Text (5 Cols) -->
                <div class="lg:col-span-5 flex flex-col gap-6">
                    <span class="text-primary font-bold text-sm tracking-widest uppercase">Booking</span>
                    <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl font-black text-text-primary leading-tight">Online Room Booking</h1>
                    <p class="text-text-secondary leading-relaxed font-medium">
                        Secure your room instantly with our encrypted booking portal. Transparent terms and instant confirmations give you absolute peace of mind.
                    </p>
                    <div class="flex flex-col gap-3 text-sm font-semibold mt-2">
                        <div class="flex items-center gap-3"><i class="fa fa-shield-halved text-primary text-lg shrink-0"></i> <span class="text-text-primary">100% Encrypted Transactions</span></div>
                        <div class="flex items-center gap-3"><i class="fa fa-file-signature text-primary text-lg shrink-0"></i> <span class="text-text-primary">Clear Digital Rental Agreement</span></div>
                        <div class="flex items-center gap-3"><i class="fa fa-circle-check text-primary text-lg shrink-0"></i> <span class="text-text-primary">Instant Booking Confirmations</span></div>
                    </div>
                </div>

                <!-- Right Side Form (7 Cols) -->
                <div class="lg:col-span-7 p-6 rounded-2xl bg-bg-body border border-border-color shadow-inner">
                    <h2 class="font-heading text-2xl font-black text-text-primary mb-6">Enter Details</h2>
                    <form action="/api/bookings" method="post" class="flex flex-col gap-4">
                        <!-- User Name & Mobile -->
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div class="flex flex-col gap-1">
                                <label for="username" class="text-xs font-bold text-text-secondary">Your Name</label>
                                <input type="text" id="username" name="username" class="w-full bg-bg-card border border-border-color rounded-xl py-3 px-4 text-sm font-semibold focus:outline-none focus:border-primary text-text-primary transition-colors" placeholder="Vikas" required>
                            </div>
                            <div class="flex flex-col gap-1">
                                <label for="mobile" class="text-xs font-bold text-text-secondary">Mobile Number</label>
                                <input type="text" id="mobile" name="mobile" class="w-full bg-bg-card border border-border-color rounded-xl py-3 px-4 text-sm font-semibold focus:outline-none focus:border-primary text-text-primary transition-colors" placeholder="+91 99999 99999" required>
                            </div>
                        </div>

                        <!-- Start Date & End Date -->
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div class="flex flex-col gap-1">
                                <label for="startDate" class="text-xs font-bold text-text-secondary">Start Date</label>
                                <input type="date" id="startDate" name="startDate" class="w-full bg-bg-card border border-border-color rounded-xl py-3 px-4 text-sm font-semibold focus:outline-none focus:border-primary text-text-primary transition-colors" required>
                            </div>
                            <div class="flex flex-col gap-1">
                                <label for="endDate" class="text-xs font-bold text-text-secondary">End Date</label>
                                <input type="date" id="endDate" name="endDate" class="w-full bg-bg-card border border-border-color rounded-xl py-3 px-4 text-sm font-semibold focus:outline-none focus:border-primary text-text-primary transition-colors" required>
                            </div>
                        </div>

                        <!-- Special Request -->
                        <div class="flex flex-col gap-1">
                            <label for="specialRequest" class="text-xs font-bold text-text-secondary">Special Request (Optional)</label>
                            <textarea id="specialRequest" name="specialRequest" rows="3" class="w-full bg-bg-card border border-border-color rounded-xl py-3 px-4 text-sm font-semibold focus:outline-none focus:border-primary text-text-primary transition-colors resize-none" placeholder="e.g. Quiet floor, study-desk preferences..."></textarea>
                        </div>

                        <!-- Hidden IDs variables -->
                        <input type="hidden" id="userId" name="userId" value="<%= user._id %>" required>
                        <input type="hidden" id="roomId" name="roomId" value="<%= typeof roomT !== 'undefined' && roomT ? roomT._id : '' %>" required>
                        <input type="hidden" id="propertyID" name="propertyID" required>

                        <!-- Submit Button -->
                        <button class="w-full py-4 bg-primary hover:bg-primary-hover text-white font-bold rounded-xl shadow-lg shadow-primary/20 hover:scale-[1.01] transition-all cursor-pointer mt-2" type="submit">
                            Confirm Booking
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </main>
    <!-- Booking Form Section End -->

    <!-- Footer Start -->
    <%- include('footer') %>
    <!-- Footer End -->

    <!-- Main JavaScript -->
    <script src="js/main.js"></script>
    <script>
        const getRoomAndProperty = () => {
            const urlParams = new URLSearchParams(window.location.search);
            const roomID = urlParams.get('roomID');
            const propertyID = urlParams.get('propertyID');
            return { roomID, propertyID };
        }
        
        document.addEventListener('DOMContentLoaded', function() {
            const { roomID, propertyID } = getRoomAndProperty();
            if (roomID) {
                document.getElementById('roomId').value = roomID;
            }
            if (propertyID) {
                document.getElementById('propertyID').value = propertyID;
            }
        });
    </script>
</body>

</html>