<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>Our Team - FMPG</title>
    <!-- Include central Tailwind Configuration -->
    <%- include('tailwind-head') %>
</head>

<body class="bg-bg-body text-text-primary transition-colors duration-300">

    <!-- Header Start -->
    <%- include('header') %>
    <!-- Header End -->

    <!-- Team Section Start -->
    <section class="py-20 max-w-7xl mx-auto px-6">
        <div class="flex flex-col gap-12 text-center">
            <div class="flex flex-col gap-2">
                <span class="text-primary font-bold text-sm tracking-widest uppercase">Team</span>
                <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-black text-text-primary tracking-tight">Core Team Members</h2>
                <p class="max-w-xl mx-auto text-text-secondary mt-2">Meet the visionaries behind Find My PG, dedicated to simplifying accommodation rentals.</p>
            </div>

            <!-- Team Grid -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Member 1: Vivek -->
                <div class="glass-panel rounded-3xl overflow-hidden shadow-xl hover:scale-[1.02] transition-premium flex flex-col group">
                    <div class="relative overflow-hidden aspect-[4/3]">
                        <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="<%= assetUrl('img/team-1.jpg') %>" alt="Vivek Kumar">
                        <!-- Floating social triggers -->
                        <div class="absolute inset-0 bg-slate-950/40 flex items-center justify-center gap-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                            <a class="h-10 w-10 rounded-full bg-white hover:bg-primary hover:text-white text-slate-800 flex items-center justify-center shadow-lg transition-all hover:scale-105" href="http://www.linkedin.com/in/vivek-kumar-2055211a6" target="_blank"><i class="fab fa-linkedin-in"></i></a>
                            <a class="h-10 w-10 rounded-full bg-white hover:bg-primary hover:text-white text-slate-800 flex items-center justify-center shadow-lg transition-all hover:scale-105" href="https://x.com/Vivekra90835697" target="_blank"><i class="fab fa-twitter"></i></a>
                            <a class="h-10 w-10 rounded-full bg-white hover:bg-primary hover:text-white text-slate-800 flex items-center justify-center shadow-lg transition-all hover:scale-105" href="https://www.instagram.com/ideal_vivek/" target="_blank"><i class="fab fa-instagram"></i></a>
                        </div>
                    </div>
                    <div class="p-6 text-center">
                        <h5 class="font-heading text-xl font-bold text-text-primary">Vivek Kumar</h5>
                        <p class="text-sm font-semibold text-primary uppercase tracking-wider mt-1">Founder & CEO</p>
                    </div>
                </div>

                <!-- Member 2: Vikas -->
                <div class="glass-panel rounded-3xl overflow-hidden shadow-xl hover:scale-[1.02] transition-premium flex flex-col group">
                    <div class="relative overflow-hidden aspect-[4/3]">
                        <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="<%= assetUrl('img/team-2.jpg') %>" alt="Vikas Adhikari">
                        <!-- Floating social triggers -->
                        <div class="absolute inset-0 bg-slate-950/40 flex items-center justify-center gap-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                            <a class="h-10 w-10 rounded-full bg-white hover:bg-primary hover:text-white text-slate-800 flex items-center justify-center shadow-lg transition-all hover:scale-105" href="https://www.linkedin.com/in/vikas-adhikari-646a0128b/" target="_blank"><i class="fab fa-linkedin-in"></i></a>
                            <a class="h-10 w-10 rounded-full bg-white hover:bg-primary hover:text-white text-slate-800 flex items-center justify-center shadow-lg transition-all hover:scale-105" href="https://x.com/vikas11652166" target="_blank"><i class="fab fa-twitter"></i></a>
                            <a class="h-10 w-10 rounded-full bg-white hover:bg-primary hover:text-white text-slate-800 flex items-center justify-center shadow-lg transition-all hover:scale-105" href="https://www.instagram.com/vikasadhikari9310/" target="_blank"><i class="fab fa-instagram"></i></a>
                        </div>
                    </div>
                    <div class="p-6 text-center">
                        <h5 class="font-heading text-xl font-bold text-text-primary">Vikas Adhikari</h5>
                        <p class="text-sm font-semibold text-primary uppercase tracking-wider mt-1">Co-Founder & COO</p>
                    </div>
                </div>

                <!-- Member 3: Adarsh -->
                <div class="glass-panel rounded-3xl overflow-hidden shadow-xl hover:scale-[1.02] transition-premium flex flex-col group">
                    <div class="relative overflow-hidden aspect-[4/3]">
                        <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="<%= assetUrl('img/team-3.jpg') %>" alt="Adarsh Kumar Panday">
                        <!-- Floating social triggers -->
                        <div class="absolute inset-0 bg-slate-950/40 flex items-center justify-center gap-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                            <a class="h-10 w-10 rounded-full bg-white hover:bg-primary hover:text-white text-slate-800 flex items-center justify-center shadow-lg transition-all hover:scale-105" href="https://tr.ee/w-AV6iY65c" target="_blank"><i class="fab fa-linkedin-in"></i></a>
                            <a class="h-10 w-10 rounded-full bg-white hover:bg-primary hover:text-white text-slate-800 flex items-center justify-center shadow-lg transition-all hover:scale-105" href="https://tr.ee/Z5812sVo3z" target="_blank"><i class="fab fa-twitter"></i></a>
                            <a class="h-10 w-10 rounded-full bg-white hover:bg-primary hover:text-white text-slate-800 flex items-center justify-center shadow-lg transition-all hover:scale-105" href="https://tr.ee/_z_ePJyZDI" target="_blank"><i class="fab fa-instagram"></i></a>
                        </div>
                    </div>
                    <div class="p-6 text-center">
                        <h5 class="font-heading text-xl font-bold text-text-primary">Adarsh Kumar Panday</h5>
                        <p class="text-sm font-semibold text-primary uppercase tracking-wider mt-1">Co-Founder & CMO</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- Team Section End -->

    <!-- Footer Start -->
    <%- include('footer') %>
    <!-- Footer End -->

    <!-- Main JavaScript -->
    <script src="js/main.js"></script>
</body>

</html>
