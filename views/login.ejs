<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>Login - FMPG</title>
    <!-- Include central Tailwind Configuration -->
    <%- include('tailwind-head') %>
</head>

<body class="bg-bg-body text-text-primary transition-colors duration-300 min-h-screen flex items-center justify-center py-12 px-6 relative overflow-hidden">
    
    <!-- Background glowing dynamic blob ornaments -->
    <div class="absolute top-[-10%] left-[-10%] h-96 w-96 rounded-full bg-primary/10 blur-3xl z-0"></div>
    <div class="absolute bottom-[-10%] right-[-10%] h-96 w-96 rounded-full bg-secondary/10 blur-3xl z-0"></div>

    <div class="w-full max-w-md z-10 animate-fade-in-up">
        <!-- Logo Header -->
        <div class="flex flex-col items-center gap-3 mb-8">
            <a href="/" class="flex items-center gap-3">
                <img src="<%= assetUrl('img/logo.png') %>" alt="FMPG Logo" class="h-12 w-auto">
                <span class="font-heading text-3xl font-extrabold text-text-primary tracking-tight">FM<span class="text-primary">PG</span></span>
            </a>
            <p class="text-sm font-semibold text-text-secondary text-center">Your hassle-free home is waiting for you</p>
        </div>

        <!-- Glassmorphic Login card -->
        <div class="glass-panel p-8 md:p-10 rounded-3xl bg-bg-card border-border-color shadow-2xl flex flex-col gap-6">
            <h2 class="font-heading text-2xl font-black text-center text-text-primary">Welcome Back</h2>

            <% if (error && error.length > 0) { %>
                <div class="p-4 rounded-xl bg-rose-500/10 border border-rose-500/20 text-rose-500 text-sm font-bold flex items-center gap-2">
                    <i class="fa fa-info-circle"></i> <%= error %>
                </div>
            <% } %>

            <!-- Main Form -->
            <form action="/login" method="POST" class="flex flex-col gap-5">
                
                <!-- Email or Mobile Input -->
                <div class="flex flex-col gap-1.5">
                    <label for="identifier" class="text-xs font-bold text-text-secondary uppercase tracking-wider">Email or Mobile</label>
                    <div class="relative flex items-center">
                        <i class="fas fa-user absolute left-4 text-text-secondary text-sm"></i>
                        <input type="text" id="identifier" name="identifier" class="w-full bg-bg-body border border-border-color rounded-2xl py-3.5 pl-11 pr-4 text-sm font-semibold focus:outline-none focus:border-primary text-text-primary transition-colors" placeholder="vikas@fmpg.com or +91 99..." required>
                    </div>
                </div>

                <!-- Password Input -->
                <div class="flex flex-col gap-1.5" id="passwordLogin">
                    <label for="password" class="text-xs font-bold text-text-secondary uppercase tracking-wider">Password</label>
                    <div class="relative flex items-center">
                        <i class="fas fa-lock absolute left-4 text-text-secondary text-sm"></i>
                        <input type="password" id="password" name="password" class="w-full bg-bg-body border border-border-color rounded-2xl py-3.5 pl-11 pr-12 text-sm font-semibold focus:outline-none focus:border-primary text-text-primary transition-colors" placeholder="••••••••" required>
                        <i class="fas fa-eye absolute right-4 text-text-secondary text-sm hover:text-primary transition-colors cursor-pointer" id="togglePassword"></i>
                    </div>
                </div>

                <!-- OTP Input Panel -->
                <div class="flex flex-col gap-1.5 hidden" id="otpLogin">
                    <label for="otp" class="text-xs font-bold text-text-secondary uppercase tracking-wider">Verification OTP</label>
                    <div class="relative flex items-center gap-2">
                        <div class="relative flex-1 flex items-center">
                            <i class="fas fa-key absolute left-4 text-text-secondary text-sm"></i>
                            <input type="text" id="otp" name="otp" class="w-full bg-bg-body border border-border-color rounded-2xl py-3.5 pl-11 pr-4 text-sm font-semibold focus:outline-none focus:border-primary text-text-primary transition-colors" placeholder="6-digit code">
                        </div>
                        <button type="button" id="sendOtp" class="px-5 py-3.5 bg-primary hover:bg-primary-hover text-white font-bold rounded-2xl shadow-md shadow-primary/10 text-xs shrink-0 transition-colors cursor-pointer">
                            Send OTP
                        </button>
                    </div>
                </div>

                <!-- Auth Mode Selector Radio Switches -->
                <div class="flex items-center justify-around py-2 border-y border-border-color text-xs font-bold text-text-secondary">
                    <label class="flex items-center gap-2 cursor-pointer hover:text-primary transition-colors">
                        <input type="radio" name="authMethod" value="password" checked class="accent-primary h-4 w-4"> 
                        Password Login
                    </label>
                    <label class="flex items-center gap-2 cursor-pointer hover:text-primary transition-colors">
                        <input type="radio" name="authMethod" value="otp" class="accent-primary h-4 w-4"> 
                        OTP Login
                    </label>
                </div>

                <!-- Links and CTA -->
                <div class="flex justify-between items-center text-xs font-bold">
                    <a href="/forgot" class="text-primary hover:underline">Forgot Password?</a>
                    <a href="/signup" class="text-secondary hover:underline">Create Account</a>
                </div>

                <button type="submit" class="w-full py-4 bg-primary hover:bg-primary-hover text-white font-bold rounded-2xl shadow-lg shadow-primary/20 hover:scale-[1.01] transition-all cursor-pointer mt-2 text-base">
                    Login
                </button>
            </form>
        </div>
    </div>

    <!-- Toggle & API logic script -->
    <script>
        const togglePassword = document.getElementById('togglePassword');
        const passwordInput = document.getElementById('password');
        const passwordLoginDiv = document.getElementById('passwordLogin');
        const otpLoginDiv = document.getElementById('otpLogin');
        const authMethodRadios = document.querySelectorAll('[name="authMethod"]');
        const sendOtpButton = document.getElementById('sendOtp');
        const identifierInput = document.getElementById('identifier');
        const otpInput = document.getElementById('otp');

        // Show/Hide password toggle
        if (togglePassword && passwordInput) {
            togglePassword.addEventListener('click', () => {
                const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                passwordInput.setAttribute('type', type);
                togglePassword.classList.toggle('fa-eye');
                togglePassword.classList.toggle('fa-eye-slash');
            });
        }

        // Switch styles between password and OTP logons
        function updateAuthMethod(method) {
            if (method === 'otp') {
                otpLoginDiv.classList.remove('hidden');
                passwordLoginDiv.classList.add('hidden');
                passwordInput.removeAttribute('required');
                passwordInput.disabled = true;
                otpInput.disabled = false;
                otpInput.setAttribute('required', 'true');
            } else {
                otpLoginDiv.classList.add('hidden');
                passwordLoginDiv.classList.remove('hidden');
                passwordInput.setAttribute('required', 'true');
                passwordInput.disabled = false;
                otpInput.removeAttribute('required');
                otpInput.disabled = true;
            }
        }

        authMethodRadios.forEach(radio => {
            radio.addEventListener('change', function() {
                updateAuthMethod(this.value);
            });
        });

        // Initialize state
        document.addEventListener('DOMContentLoaded', () => {
            const checkedRadio = document.querySelector('[name="authMethod"]:checked');
            if (checkedRadio) {
                updateAuthMethod(checkedRadio.value);
            }
        });

        // OTP Fetch request
        if (sendOtpButton) {
            sendOtpButton.addEventListener('click', () => {
                const identifier = identifierInput.value.trim();
                if (!identifier) {
                    alert('Please enter your email or mobile number first.');
                    return;
                }

                sendOtpButton.disabled = true;
                sendOtpButton.innerText = "Sending...";

                fetch('/send-otp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ identifier }),
                })
                .then(response => response.json())
                .then(data => {
                    if (data.message) {
                        alert(data.message);
                        sendOtpButton.innerText = "Resend";
                    } else {
                        alert('Failed to send OTP code. Please try again.');
                        sendOtpButton.innerText = "Send OTP";
                    }
                    sendOtpButton.disabled = false;
                })
                .catch(error => {
                    console.error('OTP Send Error:', error);
                    sendOtpButton.disabled = false;
                    sendOtpButton.innerText = "Send OTP";
                });
            });
        }
    </script>
</body>

</html>