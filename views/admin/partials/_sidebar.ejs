<aside id="admin-sidebar" class="w-64 bg-bg-card/95 backdrop-blur-md border-r border-border-color h-screen sticky top-0 flex-shrink-0 flex flex-col justify-between transition-transform duration-300 z-50 fixed md:sticky -translate-x-full md:translate-x-0">
  
  <div class="flex-1 flex flex-col min-h-0 overflow-y-auto">
    <!-- Brand Header -->
    <div class="h-20 flex items-center justify-between px-6 border-b border-border-color/60">
      <a href="/profile" class="flex items-center gap-2">
        <img src="<%= assetUrl('img/logo.png') %>" alt="FMPG Logo" class="h-10 w-10 object-contain rounded-xl shadow-sm">
        <span class="font-heading font-black text-lg tracking-wider bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">FMPG ADMIN</span>
      </a>
      
      <!-- Mobile Close Trigger -->
      <button id="close-sidebar-btn" class="md:hidden h-8 w-8 rounded-lg flex items-center justify-center border border-border-color hover:bg-primary/10 hover:text-primary transition-colors cursor-pointer" aria-label="Close sidebar">
        <i class="fa-solid fa-xmark text-sm"></i>
      </button>
    </div>

    <!-- Active Admin Profile Info -->
    <div class="px-6 py-6 border-b border-border-color/60">
      <div class="flex items-center gap-3 bg-bg-body/60 border border-border-color/60 p-3.5 rounded-2xl">
        <div class="w-10 h-10 rounded-xl bg-primary/10 text-primary border border-primary/20 flex items-center justify-center font-black font-heading text-base shadow-inner">
          <%= (typeof admin !== 'undefined' && admin) ? admin.username.charAt(0).toUpperCase() : 'A' %>
        </div>
        <div class="min-w-0 flex-1">
          <span class="block text-[10px] font-bold text-text-secondary uppercase tracking-widest mb-0.5">Welcome back</span>
          <h4 class="font-heading font-extrabold text-sm text-text-primary truncate">
            <%= (typeof admin !== 'undefined' && admin) ? admin.username : 'Admin' %>
          </h4>
        </div>
      </div>
    </div>

    <!-- Nav List Menu -->
    <nav class="flex-1 px-4 py-6 space-y-7">
      
      <!-- Group 1: Core Systems -->
      <div class="space-y-2">
        <span class="px-3 text-[10px] font-bold text-text-secondary uppercase tracking-widest block opacity-70">Core Suite</span>
        <div class="space-y-1">
          <a href="/index" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold text-text-secondary hover:text-primary hover:bg-primary/5 border border-transparent hover:border-primary/10 transition-all duration-200">
            <i class="fa-solid fa-house text-sm w-5 text-center"></i>
            <span>Home Portal</span>
          </a>
          <a href="/profile" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold text-text-secondary hover:text-primary hover:bg-primary/5 border border-transparent hover:border-primary/10 transition-all duration-200">
            <i class="fa-solid fa-gauge-high text-sm w-5 text-center"></i>
            <span>Dashboard</span>
          </a>
          <a href="/admin/analytics" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold text-text-secondary hover:text-primary hover:bg-primary/5 border border-transparent hover:border-primary/10 transition-all duration-200">
            <i class="fa-solid fa-chart-line text-sm w-5 text-center"></i>
            <span>Analytics Hub</span>
          </a>
        </div>
      </div>

      <!-- Group 2: Management systems -->
      <div class="space-y-2">
        <span class="px-3 text-[10px] font-bold text-text-secondary uppercase tracking-widest block opacity-70">Management</span>
        <div class="space-y-1">
          <a href="/admin/users" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold text-text-secondary hover:text-primary hover:bg-primary/5 border border-transparent hover:border-primary/10 transition-all duration-200">
            <i class="fa-solid fa-users text-sm w-5 text-center"></i>
            <span>Users Registry</span>
          </a>
          <a href="/admin/bookings" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold text-text-secondary hover:text-primary hover:bg-primary/5 border border-transparent hover:border-primary/10 transition-all duration-200">
            <i class="fa-solid fa-calendar-days text-sm w-5 text-center"></i>
            <span>Bookings</span>
          </a>
          <a href="/admin/properties" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold text-text-secondary hover:text-primary hover:bg-primary/5 border border-transparent hover:border-primary/10 transition-all duration-200">
            <i class="fa-solid fa-hotel text-sm w-5 text-center"></i>
            <span>Properties</span>
          </a>
          <% if (typeof admin !== 'undefined' && admin && (admin.role === 'admin' || admin.role === 'superadmin')) { %>
          <a href="/admin/audit-logs" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold text-text-secondary hover:text-primary hover:bg-primary/5 border border-transparent hover:border-primary/10 transition-all duration-200">
            <i class="fa-solid fa-clipboard-list text-sm w-5 text-center"></i>
            <span>Audit Logs</span>
          </a>
          <% } %>
        </div>
      </div>

      <!-- Group 3: Onboarding & Support -->
      <div class="space-y-2">
        <span class="px-3 text-[10px] font-bold text-text-secondary uppercase tracking-widest block opacity-70">Requests</span>
        <div class="space-y-1">
          <a href="/admin/newOwnerrequest" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold text-text-secondary hover:text-primary hover:bg-primary/5 border border-transparent hover:border-primary/10 transition-all duration-200">
            <i class="fa-solid fa-file-signature text-sm w-5 text-center"></i>
            <span>Owner Requests</span>
          </a>
          <a href="/admin/messages" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold text-text-secondary hover:text-primary hover:bg-primary/5 border border-transparent hover:border-primary/10 transition-all duration-200">
            <i class="fa-solid fa-envelope-open-text text-sm w-5 text-center"></i>
            <span>Support Enquiries</span>
          </a>
        </div>
      </div>

    </nav>
  </div>

  <!-- Sidebar Actions Footer -->
  <div class="p-4 border-t border-border-color/60 bg-bg-body/40">
    <div class="flex items-center gap-2">
      <a href="/settings" class="flex-1 flex items-center justify-center gap-1.5 px-3 py-2 rounded-xl text-xs font-bold text-text-secondary bg-bg-card hover:bg-border-color border border-border-color transition-colors" title="Settings">
        <i class="fa-solid fa-gear"></i> Settings
      </a>
      <a href="/logout" class="flex-1 flex items-center justify-center gap-1.5 px-3 py-2 rounded-xl text-xs font-bold text-white bg-red-500 hover:bg-red-600 transition-colors shadow-sm" title="Log Out">
        <i class="fa-solid fa-right-from-bracket"></i> Logout
      </a>
    </div>
  </div>

</aside>

<!-- Sidebar Overlay (For mobile screen overlay) -->
<div id="sidebar-overlay" class="hidden fixed inset-0 z-40 bg-slate-950/40 backdrop-blur-sm transition-all duration-300 md:hidden"></div>

<script>
  (function() {
    const sidebar = document.getElementById('admin-sidebar');
    const overlay = document.getElementById('sidebar-overlay');
    const closeBtn = document.getElementById('close-sidebar-btn');

    function closeSidebar() {
      sidebar.classList.add('-translate-x-full');
      overlay.classList.add('hidden');
    }

    if (closeBtn && overlay) {
      closeBtn.addEventListener('click', closeSidebar);
      overlay.addEventListener('click', closeSidebar);
    }
  })();
</script>