<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
    <meta charset="utf-8">
    <title>Page Not Found - FMPG</title>
    <link rel="icon" href="img/logo.png" type="image/icon type">
    
    <!-- Central Tailwind CSS & Theme Config -->
    <%- include('tailwind-head') %>
</head>

<body class="bg-bg-body text-text-primary min-h-screen flex flex-col transition-colors duration-300">
    <!-- Header -->
    <%- include('header') %>

    <!-- 404 Container -->
    <main class="flex-grow flex items-center justify-center py-16 px-4">
        <div class="glass-panel max-w-lg w-full rounded-2xl p-8 md:p-12 text-center animate-fade-in-up shadow-xl relative overflow-hidden">
            <!-- Decorative blur element -->
            <div class="absolute -top-12 -right-12 w-32 h-32 bg-primary/10 rounded-full blur-2xl"></div>
            <div class="absolute -bottom-12 -left-12 w-32 h-32 bg-secondary/10 rounded-full blur-2xl"></div>
            
            <div class="relative z-10">
                <!-- Icon -->
                <div class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-primary/10 text-primary mb-6 animate-pulse">
                    <i class="fa-solid fa-triangle-exclamation text-4xl"></i>
                </div>
                
                <!-- Title -->
                <h1 class="text-7xl font-extrabold tracking-tight text-primary mb-2">404</h1>
                <h2 class="text-2xl font-bold font-heading mb-4">Oops! Page Not Found</h2>
                
                <!-- Description -->
                <p class="text-text-secondary font-body mb-8 leading-relaxed">
                    The page you are looking for might have been removed, had its name changed, or is temporarily unavailable at this location.
                </p>
                
                <!-- Action Button -->
                <a href="/index" class="inline-flex items-center gap-2 bg-primary hover:bg-primary-hover text-white font-semibold px-8 py-3.5 rounded-full shadow-lg shadow-primary/25 hover:shadow-primary/40 hover:-translate-y-0.5 transition-all duration-300">
                    <i class="fa-solid fa-house"></i>
                    Go Back Home
                </a>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <%- include('footer') %>
</body>

</html>