<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>Our Services - FMPG</title>
    <!-- Include central Tailwind Configuration -->
    <%- include('tailwind-head') %>
</head>

<body class="bg-bg-body text-text-primary transition-colors duration-300">

    <!-- Header Start -->
    <%- include('header') %>
    <!-- Header End -->

    <!-- Services Section Start -->
    <section class="py-20 max-w-7xl mx-auto px-6">
        <div class="flex flex-col gap-12 text-center">
            <div class="flex flex-col gap-2">
                <span class="text-primary font-bold text-sm tracking-widest uppercase">Services</span>
                <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-black text-text-primary tracking-tight">Our Premium Offerings</h2>
                <p class="max-w-xl mx-auto text-text-secondary mt-2">Discover comfortable and hassle-free living arrangements handpicked for students and corporate professionals.</p>
            </div>

            <!-- Service items grid -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                <!-- Single Room PG Card -->
                <div class="glass-panel p-8 rounded-3xl flex flex-col items-center gap-5 text-center group cursor-pointer hover:bg-primary hover:text-white transition-premium">
                    <div class="h-16 w-16 rounded-2xl bg-primary/10 group-hover:bg-white/20 text-primary group-hover:text-white flex items-center justify-center text-3xl transition-colors">
                        <i class="fa fa-globe"></i>
                    </div>
                    <h3 class="text-xl font-bold font-heading group-hover:text-white">Single Room PG</h3>
                    <p class="text-sm text-text-secondary group-hover:text-white/80 leading-relaxed font-medium">Our single rooms are thoughtfully designed to offer you maximum comfort and absolute privacy.</p>
                </div>

                <!-- Double Room PG Card -->
                <div class="glass-panel p-8 rounded-3xl flex flex-col items-center gap-5 text-center group cursor-pointer hover:bg-primary hover:text-white transition-premium">
                    <div class="h-16 w-16 rounded-2xl bg-primary/10 group-hover:bg-white/20 text-primary group-hover:text-white flex items-center justify-center text-3xl transition-colors">
                        <i class="fa fa-hotel"></i>
                    </div>
                    <h3 class="text-xl font-bold font-heading group-hover:text-white">Double Room PG</h3>
                    <p class="text-sm text-text-secondary group-hover:text-white/80 leading-relaxed font-medium">Awesome Room with attached bathroom. Start premium shared living with your best friend.</p>
                </div>

                <!-- Flat Card -->
                <div class="glass-panel p-8 rounded-3xl flex flex-col items-center gap-5 text-center group cursor-pointer hover:bg-primary hover:text-white transition-premium">
                    <div class="h-16 w-16 rounded-2xl bg-primary/10 group-hover:bg-white/20 text-primary group-hover:text-white flex items-center justify-center text-3xl transition-colors">
                        <i class="fa fa-building"></i>
                    </div>
                    <h3 class="text-xl font-bold font-heading group-hover:text-white">Apartment / Flat</h3>
                    <p class="text-sm text-text-secondary group-hover:text-white/80 leading-relaxed font-medium">Start your independent hassle-free living with family, colleagues or friends.</p>
                </div>

                <!-- Hostel Card -->
                <div class="glass-panel p-8 rounded-3xl flex flex-col items-center gap-5 text-center group cursor-pointer hover:bg-primary hover:text-white transition-premium">
                    <div class="h-16 w-16 rounded-2xl bg-primary/10 group-hover:bg-white/20 text-primary group-hover:text-white flex items-center justify-center text-3xl transition-colors">
                        <i class="fa fa-hotel"></i>
                    </div>
                    <h3 class="text-xl font-bold font-heading group-hover:text-white">Premium Hostel</h3>
                    <p class="text-sm text-text-secondary group-hover:text-white/80 leading-relaxed font-medium">Experience secure community living with high-speed WiFi and hygienic food plans.</p>
                </div>
            </div>
        </div>
    </section>
    <!-- Services Section End -->

    <!-- Footer Start -->
    <%- include('footer') %>
    <!-- Footer End -->

    <!-- Main JavaScript -->
    <script src="js/main.js"></script>
</body>

</html>