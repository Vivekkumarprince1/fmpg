<!-- search-page -->
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>FMPG</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="" name="keywords">
    <meta content="" name="description">

    <link rel="icon" href="img/logo.png" type="image/icon type">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
        integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A=="
        crossorigin="anonymous" referrerpolicy="no-referrer" />


    <!-- Google Web Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;600&family=Nunito:wght@600;700;800&display=swap"
        rel="stylesheet">

    <!-- Icon Font Stylesheet -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Libraries Stylesheet -->
    <link href="lib/animate/animate.min.css" rel="stylesheet">
    <link href="lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">
    <link href="lib/tempusdominus/css/tempusdominus-bootstrap-4.min.css" rel="stylesheet" />

    <!-- Customized Bootstrap Stylesheet -->
    <link href="css/bootstrap.min.css" rel="stylesheet">

    <!-- Template Stylesheet -->
    <link href="css/style.css" rel="stylesheet">
    <link rel="stylesheet" href="css/footer.css">
    <style>
        .filter-section {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
}

.filter-section select, 
.filter-section button {
    padding: 10px;
    font-size: 16px;
}

    </style>
</head>

<body>
    <!-- header start -->
    <%- include('header') %>
        <!-- header end -->

        <div class="container-xxl py-5">
            <div class="container">
    
                <!-- Filter Section -->
                <div class="filter-section">
                    <input type="text" id="city-filter" class="form-control" placeholder="City" value="<%= city %>">
                    
                    <select id="gender-filter" class="form-select">
                        <option value="all" <%= gender === 'all' ? 'selected' : '' %>>All Genders</option>
                        <option value="male" <%= gender === 'male' ? 'selected' : '' %>>Male</option>
                        <option value="female" <%= gender === 'female' ? 'selected' : '' %>>Female</option>
                        <option value="unisex" <%= gender === 'unisex' ? 'selected' : '' %>>Unisex</option>
                    </select>
    
                    
                    <select id="sorting-filter" class="form-select sort">
                        <option value="relevant" <%= sort === 'relevant' ? 'selected' : '' %>>Most Relevant</option>
                        <option value="low-to-high" <%= sort === 'low-to-high' ? 'selected' : '' %>>Price: Low to High</option>
                        <option value="high-to-low" <%= sort === 'high-to-low' ? 'selected' : '' %>>Price: High to Low</option>
                        <option value="distance" <%= sort === 'distance' ? 'selected' : '' %>>Distance</option>
                    </select>
                    <button class="btn btn-primary" onclick="applyFilters()">Search</button>
                </div>

                <!-- Properties List -->
                <div class="row g-4 justify-content-center" id="properties-list">
                    <% properties.forEach(property => { %>
                    <div class="col-lg-4 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                        <div class="package-item" style="height: 500px;" onclick="readmore('<%= property._id %>')">
                            <div class="overflow-hidden">
                                <img class="img-fluid" style="height: 300px;" src="<%= assetUrl(property.images[0]) %>"
                                    alt="<%= property.propertyName %>">
                            </div>
                            <div class="d-flex border-bottom" style="color: #808b8d;">
                                <small class="flex-fill text-center border-end py-2"><%= property.type %></small>
                                <small class="flex-fill text-center border-end py-2"><i
                                        class="fa fa-calendar-alt text-primary me-2"></i>Per Month</small>
                                <small class="flex-fill text-center py-2"><i class="fa fa-user text-primary me-2"></i><%= property.capacity %></small>
                            </div>
                            <div class="text-center p-4">
                                <h3 class="mb-0"><%= property.propertyName %></h3>
                                
                                <div class="room-prices">
                                    <% if (property.rooms && property.rooms.length > 0) { %>
                                    <h6 class="mb-0">Starting Price: <%= property.rooms[0] ? property.rooms[0].price : 'N/A' %></h6>
                                    <% } else { %>
                                    
                                    <h6 class="mb-0">No rooms available</h6>
                                    <% } %>
                                </div>
                            </div>
                            <div class="d-flex justify-content-center mb-2">
                                <button class="book-btn btn-primary btn" style="border-radius: 30px;" id="book-btn"
                                    onclick="readmore('<%= property._id %>')">Book Now</button>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>
        </div>
        <!--footer start-->
        <%- include('footer') %>
        <!--footer end-->


        <!-- Template Javascript -->
        <script src="js/main.js"></script>

        <!-- Filter & Distance Logic -->
       
            <script>
                const readmore = (propertyID) => {
                    const queryString = `propertyID=${propertyID}`;
                    window.location.href = `/readmore?${queryString}`;
                };
            </script>
            <script>
                document.getElementById('gender-filter').addEventListener('change', applyFilters);
                document.getElementById('sorting-filter').addEventListener('change', applyFilters);
                document.getElementById('city-filter').addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') applyFilters();
                });
            
                async function applyFilters() {
                    const gender = document.getElementById('gender-filter').value;
                    const sort = document.getElementById('sorting-filter').value;
                    const city = document.getElementById('city-filter').value;
            
                    let queryParams = new URLSearchParams({ gender, sort, city });
            
                    // If the user selected "Distance", get their location
                    if (sort === 'distance') {
                        if (navigator.geolocation) {
                            navigator.geolocation.getCurrentPosition(async (position) => {
                                const lat = position.coords.latitude;
                                const lng = position.coords.longitude;
            
                                queryParams.append('lat', lat);
                                queryParams.append('lng', lng);
            
                                // Fetch filtered properties using AJAX
                                await fetchProperties(queryParams);
                            }, (error) => {
                                alert("Unable to retrieve your location");
                                console.error(error);
                            });
                        } else {
                            alert("Geolocation is not supported by this browser.");
                        }
                    } else {
                        // Fetch filtered properties using AJAX
                        await fetchProperties(queryParams);
                    }
                }
            
                // Function to fetch the filtered properties using Fetch API
                async function fetchProperties(queryParams) {
                    try {
                        const response = await fetch(`/search-page?${queryParams.toString()}`);
                        const data = await response.text();
            
                        // Extract the properties list part of the HTML
                        const parser = new DOMParser();
                        const htmlDoc = parser.parseFromString(data, 'text/html');
                        const propertiesList = htmlDoc.getElementById('properties-list').innerHTML;
            
                        // Update the properties list without reloading the page
                        document.getElementById('properties-list').innerHTML = propertiesList;
                    } catch (error) {
                        console.error("Error fetching properties:", error);
                    }
                }
            </script>
            
</body>

</html>