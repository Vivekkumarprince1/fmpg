<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title>FMPG Admin Management Panel</title>
  
  <!-- Include central Tailwind & Themes configuration wrapper -->
  <%- include('../../tailwind-head') %>
</head>

<body class="bg-bg-body text-text-primary transition-colors duration-300 antialiased">
  <!-- Spinner Loader Start -->
  <div id="spinner" class="fixed inset-0 z-[99999] flex items-center justify-center bg-bg-body transition-all duration-500 opacity-100 visible">
      <div class="relative flex items-center justify-center">
          <div class="h-16 w-16 animate-spin rounded-full border-4 border-solid border-primary border-t-transparent"></div>
          <div class="absolute h-6 w-6 animate-pulse rounded-full bg-secondary"></div>
      </div>
  </div>
  <script>
      (function () {
          function hideSpinner() {
              var spinner = document.getElementById('spinner');
              if (!spinner) return;
              spinner.classList.add('opacity-0', 'invisible');
              setTimeout(() => {
                  spinner.style.display = 'none';
              }, 500);
          }
          window.addEventListener('load', hideSpinner);
          setTimeout(hideSpinner, 1500);
      })();
  </script>
  <!-- Spinner Loader End -->

  <div class="flex min-h-screen bg-bg-body relative overflow-x-hidden">
    <!-- Left Sidebar Include -->
    <%- include('_sidebar') %>
    
    <!-- Main Right Content Wrapper -->
    <div class="flex-1 flex flex-col min-w-0 min-h-screen relative">
      <!-- Top Navbar Include -->
      <%- include('_navbar') %>
      
      <!-- Content Panel area -->
      <div class="flex-1">
