<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Confirm Booking & Payment - FMPG</title>
  <link rel="icon" href="/img/logo.png" type="image/icon type">
  
  <!-- Central Tailwind CSS & Theme Config -->
  <%- include('tailwind-head') %>
  
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
</head>

<body class="bg-bg-body text-text-primary min-h-screen flex flex-col transition-colors duration-300">
  <!-- Header / Navigation Placeholder to maintain uniform flow -->
  <header class="w-full border-b border-border-color bg-bg-nav backdrop-blur-md sticky top-0 z-50 transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <img src="/img/logo.png" alt="FMPG" class="w-10 h-10 object-contain">
        <span class="font-heading text-xl font-extrabold tracking-wider text-primary">FMPG</span>
      </a>
      <div class="text-xs text-text-secondary font-semibold uppercase tracking-wider bg-primary/10 text-primary border border-primary/20 px-3 py-1.5 rounded-full flex items-center gap-1">
        <i class="fa-solid fa-lock"></i> Secure Checkout
      </div>
    </div>
  </header>

  <!-- Checkout Container -->
  <main class="flex-grow flex items-center justify-center py-12 px-4">
    <div class="glass-panel max-w-xl w-full rounded-3xl p-8 md:p-10 shadow-2xl relative overflow-hidden animate-fade-in-up">
      <!-- Background highlights -->
      <div class="absolute -top-12 -left-12 w-48 h-48 bg-primary/10 rounded-full blur-3xl"></div>
      
      <div class="relative z-10">
        <!-- Title & Step Progress -->
        <div class="text-center mb-8">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-primary/10 text-primary mb-4 animate-bounce">
            <i class="fa-solid fa-receipt text-2xl"></i>
          </div>
          <h1 class="text-2xl md:text-3xl font-extrabold font-heading text-text-primary">Confirm Your Booking</h1>
          <p class="text-text-secondary text-sm mt-1">Please review details and complete the verification fee below.</p>
        </div>

        <!-- Receipt / Invoice Card -->
        <div class="bg-bg-body/60 border border-border-color rounded-2xl p-6 mb-8 space-y-4 shadow-inner">
          <h3 class="text-xs font-bold text-text-secondary uppercase tracking-widest border-b border-border-color pb-2">Booking Receipt</h3>
          
          <div class="space-y-3">
            <div class="flex justify-between items-center text-sm">
              <span class="text-text-secondary font-medium"><i class="fa-solid fa-building text-xs mr-2"></i>Property Name</span>
              <span class="text-text-primary font-semibold text-right">The Sunshine Hostel</span>
            </div>
            
            <div class="flex justify-between items-center text-sm">
              <span class="text-text-secondary font-medium"><i class="fa-solid fa-bed text-xs mr-2"></i>Room Type</span>
              <span class="text-text-primary font-semibold text-right capitalize">Single Deluxe</span>
            </div>
            
            <div class="grid grid-cols-2 gap-4 border-t border-dashed border-border-color pt-3 mt-3 text-sm">
              <div>
                <span class="block text-[10px] uppercase font-bold text-text-secondary tracking-wider mb-0.5">Check-In Date</span>
                <span class="text-text-primary font-semibold"><%= typeof startDate !== 'undefined' ? new Date(startDate).toDateString() : '01-Jan-2025' %></span>
              </div>
              <div class="text-right">
                <span class="block text-[10px] uppercase font-bold text-text-secondary tracking-wider mb-0.5">Check-Out Date</span>
                <span class="text-text-primary font-semibold"><%= typeof endDate !== 'undefined' ? new Date(endDate).toDateString() : '07-Jan-2025' %></span>
              </div>
            </div>

            <% if (typeof specialRequest !== 'undefined' && specialRequest) { %>
              <div class="border-t border-dashed border-border-color pt-3 text-sm">
                <span class="block text-[10px] uppercase font-bold text-text-secondary tracking-wider mb-1">Special Request</span>
                <p class="text-text-secondary italic text-xs bg-bg-body p-2.5 rounded-xl border border-border-color"><%= specialRequest %></p>
              </div>
            <% } %>

            <!-- Price highlight box -->
            <div class="bg-primary/10 border border-primary/20 rounded-xl p-4 flex items-center justify-between mt-4">
              <div>
                <span class="block text-[10px] uppercase font-bold text-primary tracking-wider font-heading">Verification Fee</span>
                <span class="text-xs text-text-secondary">Fully refundable / deductible on rent</span>
              </div>
              <div class="text-right">
                <span class="text-2xl font-extrabold text-primary font-heading">₹<%= typeof order !== 'undefined' ? order.amount / 100 : '500' %></span>
              </div>
            </div>
          </div>
        </div>

        <!-- Checkout Action Button -->
        <button id="rzp-button" class="w-full bg-primary hover:bg-primary-hover text-white font-bold py-4 rounded-xl shadow-lg shadow-primary/25 hover:shadow-primary/45 transition-all duration-300 text-lg flex items-center justify-center gap-2 hover:-translate-y-0.5 cursor-pointer">
          <i class="fa-solid fa-credit-card"></i>
          Pay ₹<%= typeof order !== 'undefined' ? order.amount / 100 : '500' %> Now
        </button>

        <p class="text-center text-[10px] text-text-secondary mt-4 flex items-center justify-center gap-1 select-none">
          <i class="fa-solid fa-shield-halved text-primary"></i> 256-bit SSL Encrypted Transaction. Razorpay Gateway.
        </p>
      </div>
    </div>
  </main>

  <!-- Footer block -->
  <footer class="w-full border-t border-border-color py-6 text-center text-xs text-text-secondary bg-bg-body transition-colors duration-300">
    <p>&copy; <%= new Date().getFullYear() %> FMPG. All rights reserved.</p>
  </footer>

  <script>
    const options = {
      key: "<%= process.env.RAZORPAY_KEY_ID %>",
      amount: "<%= order.amount %>",
      currency: "INR",
      name: "FMPG",
      description: "Room Booking Payment",
      order_id: "<%= order.id %>",
      handler: function (response) {
        const data = {
          payment_id: response.razorpay_payment_id,
          order_id: response.razorpay_order_id,
          signature: response.razorpay_signature,
          userId: "<%= userId %>",
          roomId: "<%= roomId %>",
          propertyID: "<%= propertyID %>",
          mobile: "<%= mobile %>",
          startDate: "<%= startDate %>",
          endDate: "<%= endDate %>",
          specialRequest: "<%= specialRequest %>",
          username: "<%= username %>",
        };

        fetch('/api/bookings/payment-success', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        })
          .then(response => response.json())
          .then(result => {
            if (result.success) {
              alert('Payment successful!');
              window.location.href = result.redirect;
            } else {
              alert('Payment failed: ' + result.message);
            }
          });
      },
      theme: {
        color: "#10b981"
      }
    };

    const rzp = new Razorpay(options);
    document.getElementById('rzp-button').onclick = () => rzp.open();
  </script>
</body>

</html>