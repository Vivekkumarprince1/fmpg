<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
    <meta charset="utf-8">
    <title>Frequently Asked Questions - FMPG</title>
    <link rel="icon" href="/img/logo.png" type="image/icon type">
    
    <!-- Central Tailwind CSS & Theme Config -->
    <%- include('tailwind-head') %>
</head>

<body class="bg-bg-body text-text-primary min-h-screen flex flex-col transition-colors duration-300">
    <!-- Header -->
    <%- include('header') %>

    <!-- FAQs Hero Section -->
    <section class="py-12 md:py-16 bg-gradient-to-b from-primary/5 to-transparent">
        <div class="max-w-4xl mx-auto px-4 text-center">
            <h1 class="text-3xl md:text-5xl font-extrabold font-heading text-primary mb-4">Frequently Asked Questions</h1>
            <p class="text-text-secondary max-w-xl mx-auto leading-relaxed">Find quick answers to common queries about PG bookings, advance deposits, verification protocols, and cancellation policies.</p>
        </div>
    </section>

    <!-- FAQs Accordion List -->
    <main class="flex-grow max-w-4xl mx-auto w-full px-4 pb-16">
        <div class="glass-panel rounded-3xl p-6 md:p-10 shadow-xl border border-border-color space-y-6">
            
            <!-- Dynamic FAQ Items -->
            <% 
              const faqList = [
                { q: "What types of accommodations do you offer?", a: "We offer a variety of PG accommodations including single rooms, shared rooms, and dormitory-style arrangements. Some PGs come with additional amenities like meals, Wi-Fi, laundry, and housekeeping." },
                { q: "How do I book a PG through your service?", a: "You can book a PG by contacting us directly or through our website/app. Once you choose a PG, we’ll guide you through the booking and payment process." },
                { q: "What payment methods are accepted?", a: "We accept various payment methods including UPI, cards, and digital wallets. You can choose the payment method that is most convenient for you." },
                { q: "Do I need to pay any advance or deposit?", a: "Most PGs require a security deposit along with the first month’s rent. The deposit amount varies depending on the PG and location. We will inform you of any deposit requirements during the booking process." },
                { q: "Is there any service charge for using your platform?", a: "Yes, we charge a nominal service fee for helping you find and book your PG. The exact fee will be communicated to you before you finalize your booking." },
                { q: "How do you verify the PGs listed on your platform?", a: "We conduct thorough checks to verify the authenticity and quality of each PG listed on our platform. This includes background checks, visits, and reviews from previous tenants." },
                { q: "What if I face any issues after moving in?", a: "We offer post-booking support to help you with any issues or concerns that may arise after you move in. You can reach out to our customer support team for assistance." },
                { q: "Can I cancel my booking?", a: "Yes, you can cancel your booking, but the cancellation policy depends on the specific PG’s terms. Some PGs may offer a full or partial refund, while others may have a non-refundable policy." },
                { q: "How do I get a refund if I cancel my booking?", a: "If you are eligible for a refund based on the PG’s cancellation policy, we will process your refund within 5 working days. The refund will be credited to your original payment method." },
                { q: "What if I want to change my PG after moving in?", a: "If you wish to move to a different PG after moving in, we can assist you in finding a new place. However, any financial implications, such as forfeiture of deposit, depend on the original PG’s terms." },
                { q: "How can I contact customer support?", a: "You can contact our customer support team via phone, email, or live chat on our website. We are available daily to assist you with any queries or issues." },
                { q: "Do you offer assistance with relocation?", a: "Yes, we can assist with your relocation by connecting you with reliable movers and packers. This service is optional and comes with an additional cost." },
                { q: "Can I schedule a visit to the PG before booking?", a: "Yes, you can schedule a visit to any PG before making your booking. We recommend visiting the PG to ensure it meets your expectations." }
              ];
            %>

            <div class="space-y-4">
                <% faqList.forEach((faq, index) => { %>
                    <details class="group bg-bg-body border border-border-color rounded-2xl p-5 [&_summary::-webkit-details-marker]:hidden transition-all duration-300">
                        <summary class="flex items-center justify-between cursor-pointer focus:outline-none">
                            <h3 class="font-heading font-extrabold text-sm md:text-base text-text-primary group-open:text-primary transition-colors pr-4">
                                <%= index + 1 %>. <%= faq.q %>
                            </h3>
                            <span class="w-7 h-7 rounded-xl bg-primary/10 text-primary flex items-center justify-center group-open:rotate-180 transition-transform duration-300">
                                <i class="fa-solid fa-chevron-down text-xs"></i>
                            </span>
                        </summary>
                        <p class="mt-4 text-xs md:text-sm text-text-secondary leading-relaxed font-body border-t border-border-color/60 pt-4">
                            <%= faq.a %>
                        </p>
                    </details>
                <% }) %>
            </div>

            <!-- Still Need Help Box -->
            <div class="bg-primary/5 border border-primary/10 rounded-2xl p-6 text-center mt-8 space-y-3">
                <h4 class="font-heading font-bold text-lg">Still have questions?</h4>
                <p class="text-xs md:text-sm text-text-secondary">Can't find the answers you're looking for? Reach out to our dedicated support desk.</p>
                <a href="/contact" class="inline-flex items-center gap-1.5 bg-primary hover:bg-primary-hover text-white text-xs font-semibold px-6 py-2.5 rounded-xl shadow-md shadow-primary/20 hover:scale-[1.01] transition-all cursor-pointer">
                    <i class="fa-solid fa-envelope"></i> Contact Support Desk
                </a>
            </div>

        </div>
    </main>

    <!-- Footer -->
    <%- include('footer') %>
</body>

</html>