NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://localhost:27017/fmpg

SESSION_SECRET=replace-with-strong-session-secret
JWT_SECRET=replace-with-strong-jwt-secret

RAZORPAY_KEY_ID=replace-with-razorpay-key-id
RAZORPAY_KEY_SECRET=replace-with-razorpay-key-secret

EMAIL_SERVICE=gmail
EMAIL_USER=replace-with-email-user
EMAIL_PASS=replace-with-email-password
EMAIL_FROM=no-reply@example.com

GLOBAL_RATE_LIMIT=400
AUTH_RATE_LIMIT=20
OTP_RATE_LIMIT=5
OTP_EXPIRY_MINUTES=10
STATIC_MAX_AGE=1d
LOG_LEVEL=info