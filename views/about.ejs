<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>About Us - FMPG</title>
    <!-- Include central Tailwind Configuration -->
    <%- include('tailwind-head') %>
</head>

<body class="bg-bg-body text-text-primary transition-colors duration-300">

    <!-- Header Start -->
    <%- include('header') %>
    <!-- Header End -->

    <!-- About Section Start -->
    <section class="py-20 max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center animate-fade-in-up">
            <!-- About Image with floating stats -->
            <div class="relative rounded-3xl overflow-hidden shadow-2xl aspect-[4/3] group">
                <img class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="<%= assetUrl('img/about.jpg') %>" alt="Comfortable Room Living">
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950/60 to-transparent"></div>
                <!-- Mini floating stat banner -->
                <div class="absolute bottom-6 left-6 right-6 p-6 rounded-2xl bg-white/10 backdrop-blur-md border border-white/20 text-white flex items-center justify-between">
                    <div>
                        <span class="text-2xl font-extrabold text-primary">100%</span>
                        <p class="text-xs text-slate-300 font-semibold">Verified PGs</p>
                    </div>
                    <div class="h-8 w-[1px] bg-white/20"></div>
                    <div>
                        <span class="text-2xl font-extrabold text-secondary">24/7</span>
                        <p class="text-xs text-slate-300 font-semibold">Live Support</p>
                    </div>
                </div>
            </div>

            <!-- About Text -->
            <div class="flex flex-col gap-6 items-start">
                <div class="flex flex-col gap-2">
                    <span class="text-primary font-bold text-sm tracking-widest uppercase">About Us</span>
                    <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-black text-text-primary tracking-tight">
                        Welcome to <span class="text-primary">FMPG</span>
                    </h2>
                </div>
                
                <p class="text-text-secondary leading-relaxed text-base font-medium">
                    FMPG is your premier choice for hassle-free and comfortable hostel/PG living! We pride ourselves on creating a home away from home, offering you a perfect blend of modern convenience, tight security, and inclusive community.
                </p>
                <p class="text-text-secondary leading-relaxed text-base">
                    Our single and shared rooms are thoughtfully designed to offer you maximum comfort and privacy. Each property is handpicked and fully furnished with snug beds, wardrobes, study desks, high-speed WiFi, air conditioning, and hygiene-assured bathrooms.
                </p>

                <!-- Checkmarks Grid -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 w-full mt-2">
                    <div class="flex items-center gap-3">
                        <div class="h-6 w-6 rounded-full bg-primary/10 text-primary flex items-center justify-center text-xs">
                            <i class="fa fa-check"></i>
                        </div>
                        <span class="text-sm font-semibold text-text-primary">Handpicked Verified PGs</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="h-6 w-6 rounded-full bg-primary/10 text-primary flex items-center justify-center text-xs">
                            <i class="fa fa-check"></i>
                        </div>
                        <span class="text-sm font-semibold text-text-primary">Instant Online Payouts</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="h-6 w-6 rounded-full bg-primary/10 text-primary flex items-center justify-center text-xs">
                            <i class="fa fa-check"></i>
                        </div>
                        <span class="text-sm font-semibold text-text-primary">24/7 Direct Help Desk</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="h-6 w-6 rounded-full bg-primary/10 text-primary flex items-center justify-center text-xs">
                            <i class="fa fa-check"></i>
                        </div>
                        <span class="text-sm font-semibold text-text-primary">Zero Hidden Fees</span>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- About Section End -->

    <!-- Footer Start -->
    <%- include('footer') %>
    <!-- Footer End -->

    <!-- Main JavaScript -->
    <script src="js/main.js"></script>
</body>

</html>