<!-- Header Stickiness Logic & Sidebars Script -->
<script>
    (function() {
        const header = document.getElementById('sticky-header');
        const mobileBtn = document.getElementById('mobile-menu-btn');
        const closeBtn = document.getElementById('close-sidebar-btn');
        const sidebar = document.getElementById('mobile-sidebar');

        // Sticky effect on scroll
        const checkScroll = () => {
            if (window.scrollY > 40) {
                header.classList.remove('bg-transparent', 'border-transparent', 'py-5');
                header.classList.add('bg-bg-nav', 'backdrop-blur-md', 'border-border-color', 'shadow-sm', 'py-3.5', 'fixed', 'top-0', 'left-0');
                header.style.boxShadow = '0 10px 30px -10px rgba(5, 150, 105, 0.06)';
            } else {
                header.classList.remove('bg-bg-nav', 'backdrop-blur-md', 'border-border-color', 'shadow-sm', 'py-3.5', 'fixed', 'top-0', 'left-0');
                header.classList.add('bg-transparent', 'border-transparent', 'py-5');
                header.style.boxShadow = 'none';
            }
        };

        window.addEventListener('scroll', checkScroll);
        // Run initial check
        checkScroll();

        // Sidebar interactions
        if (mobileBtn && sidebar) {
            mobileBtn.addEventListener('click', () => {
                sidebar.classList.remove('translate-x-full');
            });
        }
        if (closeBtn && sidebar) {
            closeBtn.addEventListener('click', () => {
                sidebar.classList.add('translate-x-full');
            });
        }

        // Dropdown interactions (touch + click reliability)
        const pagesTrigger = document.getElementById('pages-dropdown-trigger');
        const pagesMenu = document.getElementById('pages-dropdown-menu');
        const pagesChevron = document.getElementById('pages-chevron');
        const pagesWrapper = document.getElementById('pages-dropdown-wrapper');

        if (pagesTrigger && pagesMenu) {
            pagesTrigger.addEventListener('click', (e) => {
                e.stopPropagation();
                const isOpen = !pagesMenu.classList.contains('invisible');
                if (isOpen) {
                    pagesMenu.classList.add('opacity-0', 'invisible', 'translate-y-2');
                    pagesMenu.classList.remove('opacity-100', 'visible', 'translate-y-0');
                    if (pagesChevron) pagesChevron.classList.remove('rotate-180');
                } else {
                    pagesMenu.classList.remove('opacity-0', 'invisible', 'translate-y-2');
                    pagesMenu.classList.add('opacity-100', 'visible', 'translate-y-0');
                    if (pagesChevron) pagesChevron.classList.add('rotate-180');
                }
            });

            document.addEventListener('click', (e) => {
                if (pagesWrapper && !pagesWrapper.contains(e.target)) {
                    pagesMenu.classList.add('opacity-0', 'invisible', 'translate-y-2');
                    pagesMenu.classList.remove('opacity-100', 'visible', 'translate-y-0');
                    if (pagesChevron) pagesChevron.classList.remove('rotate-180');
                }
            });
        }
    })();
</script>
