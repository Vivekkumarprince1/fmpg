<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>FMPG - Hassle Free Premium Living</title>
    <!-- Include central Tailwind Configuration -->
    <%- include('tailwind-head') %>
    
    <style>
        /* Custom alerts styling to fit dark/light seamlessly */
        .alert-custom {
            animation: fadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards, fadeOut 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards 3.5s;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translate(-50%, -60%); }
            to { opacity: 1; transform: translate(-50%, -50%); }
        }

        @keyframes fadeOut {
            from { opacity: 1; transform: translate(-50%, -50%); }
            to { opacity: 0; transform: translate(-50%, -40%); }
        }
    </style>
</head>

<body class="bg-bg-body text-text-primary transition-colors duration-300">

    <!-- Header Start (Contains Spinner, Social Topbar, Sticky Navbar) -->
    <%- include('header') %>
    <!-- Header End -->

    <!-- Display dynamic success/notification alerts -->
    <% if (typeof success !=='undefined' && success) { %>
        <div class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-[10000] w-[90%] max-w-md p-6 rounded-3xl bg-primary text-white font-bold text-center shadow-2xl backdrop-blur-md alert-custom" id="message-alert" style="box-shadow: var(--shadow-gold)">
            <div class="flex flex-col items-center gap-3">
                <i class="fa-regular fa-circle-check text-4xl"></i>
                <span class="text-lg font-heading tracking-wide"><%= success %></span>
            </div>
        </div>
    <% } %>

    <!-- Hero Search Section Start (Overhauled to Premium White Canvas with Isometric 3D Collage) -->
    <section class="relative w-full overflow-hidden bg-white bg-grid-pattern pt-16 pb-24 lg:py-32">
        <!-- Luxury ambient glowing background elements -->
        <div class="absolute -top-40 -left-40 w-96 h-96 bg-primary/4 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute top-60 right-0 w-[450px] h-[450px] bg-primary/4 rounded-full blur-[110px] pointer-events-none"></div>
        
        <div class="relative max-w-7xl mx-auto px-6 md:px-12 z-10 grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
            <!-- Left Side: Copywriting & 3D Search Command Panel -->
            <div class="lg:col-span-7 flex flex-col items-start gap-6 text-left animate-fade-in-up">
                <!-- Golden Badge -->
                <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-bold uppercase tracking-widest shadow-sm">
                    <i class="fa fa-home"></i> Premium Real Estate Living
                </span>
                
                <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight text-text-primary leading-tight">
                    Enjoy Your <br><span class="text-primary relative inline-block">Hassle-Free<span class="absolute left-0 bottom-1 w-full h-[6px] bg-primary/15 rounded"></span></span> Living Space
                </h1>
                
                <p class="max-w-xl text-base sm:text-lg text-text-secondary font-medium leading-relaxed">
                    Your exclusive home away from home. Discover premium, handpicked, verified accommodations curated specifically for students and professionals.
                </p>
                
                <!-- Search Panel (Redesigned as floating 3D commands card) -->
                <div class="card-3d w-full max-w-2xl mt-4 relative">
                    <div class="glass-panel rounded-3xl p-3 bg-white/95 border-primary/25 hover:border-primary/40 flex flex-col sm:flex-row items-stretch gap-2.5 shadow-gold">
                        <div class="relative flex-1 flex items-center">
                            <i class="fa fa-map-marker-alt text-primary absolute left-4 text-lg pop-3d"></i>
                            <input class="w-full bg-transparent py-4 pl-12 pr-12 text-text-primary placeholder-slate-400 font-bold border-0 focus:outline-none focus:ring-0 text-base" id="input" type="text" placeholder="Where do you want to live? (e.g. Hoshiarpur)" autocapitalize="on" required>
                            
                            <!-- Near Me GPS button -->
                            <button type="button" class="absolute right-4 text-text-secondary hover:text-primary transition-colors cursor-pointer pop-3d" id="near-me-btn" title="Detect location">
                                <i class="fa-solid fa-location-crosshairs text-lg"></i>
                            </button>
                        </div>

                        <!-- Search submit button -->
                        <button type="button" class="px-8 py-4 bg-primary text-white font-black uppercase tracking-wider text-sm rounded-2xl shadow-md hover:bg-primary-hover hover:scale-[1.02] transition-all cursor-pointer disabled:opacity-50 disabled:pointer-events-none pop-3d" id="search-btn" disabled style="box-shadow: 0 4px 12px rgba(5, 150, 105, 0.15)">
                            <i class="fa fa-search mr-2"></i> Find PG
                        </button>

                        <!-- Suggestions Dropdown list -->
                        <div class="suggestions-container absolute top-full left-0 right-0 mt-3 rounded-2xl border border-border-color bg-white p-2 shadow-xl z-[999] max-h-56 overflow-y-auto text-text-primary text-left" id="dropdown" style="display: none;"></div>
                    </div>
                </div>
            </div>

            <!-- Right Side: Beautiful 3D Layered Isometric Collage (Premium Real Estate Concept) -->
            <div class="lg:col-span-5 hidden lg:block relative h-[420px] preserve-3d animate-fade-in-up">
                <!-- Background decorative luxury circle frame -->
                <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 h-80 rounded-full border-2 border-dashed border-primary/15 animate-spin-slow"></div>
                
                <!-- Main Layer: Premium Villa Image Card (Skewed slightly) -->
                <div class="card-3d absolute top-6 left-6 w-80 h-72 rounded-[32px] overflow-hidden shadow-2xl border-4 border-white transition-premium cursor-pointer" style="transform: rotate(-4deg) rotateY(15deg);">
                    <img class="w-full h-full object-cover" src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=600&q=80" alt="Premium Living Villa">
                    <div class="absolute inset-0 bg-gradient-to-t from-slate-950/40 to-transparent"></div>
                </div>

                <!-- Overlapping Floating Card 1: Rating Badge (Pops in 3D) -->
                <div class="card-3d absolute bottom-12 -left-4 px-5 py-3 rounded-2xl bg-white border border-border-color shadow-gold flex items-center gap-2.5 transition-premium cursor-pointer" style="transform: translateZ(60px) rotate(4deg);">
                    <div class="h-8 w-8 rounded-full bg-primary/10 flex items-center justify-center text-primary text-sm font-black">★</div>
                    <div>
                        <p class="text-xs font-black text-text-primary">4.9 / 5.0 Rated</p>
                        <p class="text-[9px] text-text-secondary font-semibold uppercase tracking-wider">Premium Standard</p>
                    </div>
                </div>

                <!-- Overlapping Floating Card 2: Micro Property Tag (Pops in 3D) -->
                <div class="card-3d absolute top-12 right-2 px-5 py-3.5 rounded-2xl bg-slate-950 text-white shadow-2xl flex items-center gap-3 transition-premium cursor-pointer" style="transform: translateZ(80px) rotate(-6deg);">
                    <i class="fa fa-circle-check text-primary text-lg"></i>
                    <div>
                        <p class="text-xs font-black">100% Verified</p>
                        <p class="text-[9px] text-primary font-bold uppercase tracking-widest">Secure Homes</p>
                    </div>
                </div>

                <!-- Extra Decorative Grid Elements -->
                <div class="absolute bottom-2 right-12 text-primary/30 text-5xl opacity-40"><i class="fa-solid fa-grid-2 animate-pulse"></i></div>
            </div>
        </div>
    </section>
    <!-- Hero Search Section End -->


    <!-- About Section Start (Refactored to Premium Layout with Staggered GSAP) -->
    <section class="py-24 max-w-7xl mx-auto px-6 md:px-12 bg-white">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
            <!-- Left Column: About Image & Interactive 3D Stat Banner -->
            <div class="lg:col-span-6 relative aspect-[4/3] w-full rounded-[40px] overflow-hidden shadow-2xl border border-border-color-light group gsap-reveal">
                <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" src="<%= assetUrl('img/about.jpg') %>" alt="Comfortable Hostel Room">
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950/40 to-transparent"></div>
                
                <!-- Floating 3D Stat Banner (Redesigned as luxurious glass panel) -->
                <div class="card-3d absolute bottom-6 left-6 right-6 p-6 rounded-3xl bg-white/90 backdrop-blur-md border border-primary/20 text-text-primary flex items-center justify-between shadow-gold">
                    <div class="text-center flex-1">
                        <span class="text-3xl font-black text-primary font-heading tracking-tight flex justify-center items-center gap-0.5">
                            <span class="gsap-counter" data-target="100">0</span>%
                        </span>
                        <p class="text-[10px] text-text-secondary font-black uppercase tracking-widest mt-1 pop-3d">Verified Units</p>
                    </div>
                    <div class="h-10 w-[1px] bg-border-color"></div>
                    <div class="text-center flex-1">
                        <span class="text-3xl font-black text-secondary font-heading tracking-tight flex justify-center items-center gap-0.5">
                            24/7
                        </span>
                        <p class="text-[10px] text-text-secondary font-black uppercase tracking-widest mt-1 pop-3d">Live Help Desk</p>
                    </div>
                </div>
            </div>

            <!-- Right Column: About Content (Staggered Entrance) -->
            <div class="lg:col-span-6 flex flex-col gap-6 items-start text-left gsap-slide-in" data-side="right">
                <div class="flex flex-col gap-2">
                    <span class="text-primary font-black text-xs tracking-widest uppercase relative pl-8 before:absolute before:left-0 before:top-1/2 before:-translate-y-1/2 before:h-[2px] before:w-6 before:bg-primary">Exclusive Choice</span>
                    <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-black text-text-primary tracking-tight leading-tight">
                        Welcome to <span class="text-primary">FMPG</span> Portal
                    </h2>
                </div>
                
                <p class="text-text-secondary leading-relaxed text-base font-semibold">
                    FMPG is your premier portal for high-end, comfortable student and professional PG living. We provide verified luxury stays that bridge modern convenience with structural security.
                </p>
                <p class="text-text-secondary leading-relaxed text-sm">
                    Our meticulously curated single and shared suites are tailored to offer optimal privacy. Each accommodation is fully furnished and equipped with robust high-speed Wi-Fi, air conditioning, snug beds, study counters, and premium hygienic restrooms.
                </p>

                <!-- Checkmarks Grid (Redesigned with gold check dots) -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 w-full mt-3">
                    <div class="flex items-center gap-3">
                        <div class="h-6 w-6 rounded-full bg-primary/10 text-primary flex items-center justify-center text-xs shadow-sm">
                            <i class="fa fa-check"></i>
                        </div>
                        <span class="text-sm font-bold text-text-primary uppercase tracking-wide text-xs">Handpicked Luxury PGs</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="h-6 w-6 rounded-full bg-primary/10 text-primary flex items-center justify-center text-xs shadow-sm">
                            <i class="fa fa-check"></i>
                        </div>
                        <span class="text-sm font-bold text-text-primary uppercase tracking-wide text-xs">Direct Paperless Booking</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="h-6 w-6 rounded-full bg-primary/10 text-primary flex items-center justify-center text-xs shadow-sm">
                            <i class="fa fa-check"></i>
                        </div>
                        <span class="text-sm font-bold text-text-primary uppercase tracking-wide text-xs">Dedicated Concierge</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="h-6 w-6 rounded-full bg-primary/10 text-primary flex items-center justify-center text-xs shadow-sm">
                            <i class="fa fa-check"></i>
                        </div>
                        <span class="text-sm font-bold text-text-primary uppercase tracking-wide text-xs">100% Pricing Integrity</span>
                    </div>
                </div>

                <a class="mt-4 px-8 py-4 bg-primary text-white font-heading text-xs font-black uppercase tracking-widest rounded-2xl shadow-gold hover:bg-primary-hover hover:scale-105 transition-all duration-300" href="about">
                    Learn More About Us
                </a>
            </div>
        </div>
    </section>
    <!-- About Section End -->


    <!-- Services Section Start (Redesigned as Staggered 3D Cards) -->
    <section class="py-24 bg-bg-body-alt border-y border-border-color transition-colors duration-300">
        <div class="max-w-7xl mx-auto px-6 md:px-12 text-center flex flex-col gap-16">
            <div class="flex flex-col gap-2 items-center gsap-reveal">
                <span class="text-primary font-black text-xs tracking-widest uppercase pl-8 relative before:absolute before:left-0 before:top-1/2 before:-translate-y-1/2 before:h-[2px] before:w-6 before:bg-primary">Curated Portfolios</span>
                <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-black text-text-primary tracking-tight">Our Elite Categories</h2>
            </div>

            <!-- Service items grid (Equipped with GSAP staggers & 3D tilt) -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 gsap-stagger">
                <!-- Single Room PG Card -->
                <div class="card-3d glass-panel p-8 rounded-[32px] flex flex-col items-center gap-5 text-center group cursor-pointer hover:bg-primary hover:text-white transition-premium bg-white gsap-stagger-item">
                    <div class="h-16 w-16 rounded-2xl bg-primary/10 group-hover:bg-white/20 text-primary group-hover:text-white flex items-center justify-center text-3xl transition-colors shadow-sm pop-3d">
                        <i class="fa fa-globe"></i>
                    </div>
                    <h3 class="text-lg font-black font-heading group-hover:text-white uppercase tracking-wider mt-2">Single Room</h3>
                    <p class="text-xs text-text-secondary group-hover:text-white/80 leading-relaxed font-semibold">Exquisite solo chambers designed to host your absolute work-focus and private comfort.</p>
                </div>

                <!-- Double Room PG Card -->
                <div class="card-3d glass-panel p-8 rounded-[32px] flex flex-col items-center gap-5 text-center group cursor-pointer hover:bg-primary hover:text-white transition-premium bg-white gsap-stagger-item">
                    <div class="h-16 w-16 rounded-2xl bg-primary/10 group-hover:bg-white/20 text-primary group-hover:text-white flex items-center justify-center text-3xl transition-colors shadow-sm pop-3d">
                        <i class="fa fa-hotel"></i>
                    </div>
                    <h3 class="text-lg font-black font-heading group-hover:text-white uppercase tracking-wider mt-2">Shared Suites</h3>
                    <p class="text-xs text-text-secondary group-hover:text-white/80 leading-relaxed font-semibold">Spacious chambers with custom bathroom fittings. Ideal shared layouts for peers.</p>
                </div>

                <!-- Flat Card -->
                <div class="card-3d glass-panel p-8 rounded-[32px] flex flex-col items-center gap-5 text-center group cursor-pointer hover:bg-primary hover:text-white transition-premium bg-white gsap-stagger-item">
                    <div class="h-16 w-16 rounded-2xl bg-primary/10 group-hover:bg-white/20 text-primary group-hover:text-white flex items-center justify-center text-3xl transition-colors shadow-sm pop-3d">
                        <i class="fa fa-building"></i>
                    </div>
                    <h3 class="text-lg font-black font-heading group-hover:text-white uppercase tracking-wider mt-2">Independent Flat</h3>
                    <p class="text-xs text-text-secondary group-hover:text-white/80 leading-relaxed font-semibold">Premium separate structures matching family comfort, friends stay, or team relocations.</p>
                </div>

                <!-- Hostel Card -->
                <div class="card-3d glass-panel p-8 rounded-[32px] flex flex-col items-center gap-5 text-center group cursor-pointer hover:bg-primary hover:text-white transition-premium bg-white gsap-stagger-item">
                    <div class="h-16 w-16 rounded-2xl bg-primary/10 group-hover:bg-white/20 text-primary group-hover:text-white flex items-center justify-center text-3xl transition-colors shadow-sm pop-3d">
                        <i class="fa fa-hotel"></i>
                    </div>
                    <h3 class="text-lg font-black font-heading group-hover:text-white uppercase tracking-wider mt-2">Premium Hostels</h3>
                    <p class="text-xs text-text-secondary group-hover:text-white/80 leading-relaxed font-semibold">Vibrant community spaces integrated with solid digital systems and organic meals.</p>
                </div>
            </div>
        </div>
    </section>
    <!-- Services Section End -->


    <!-- Top Rooms Section Start (Redesigned as High-End Real Estate Listings) -->
    <section class="py-24 max-w-7xl mx-auto px-6 md:px-12 flex flex-col gap-16 bg-white">
        <div class="flex flex-col gap-2 items-center text-center gsap-reveal">
            <span class="text-primary font-black text-xs tracking-widest uppercase pl-8 relative before:absolute before:left-0 before:top-1/2 before:-translate-y-1/2 before:h-[2px] before:w-6 before:bg-primary">Top Recommendations</span>
            <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-black text-text-primary tracking-tight">Luxury Accommodations</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 gsap-stagger">
            <% properties.slice(0, 3).forEach(property => { %>
                <article class="card-3d glass-panel rounded-[32px] overflow-hidden cursor-pointer flex flex-col group transition-premium bg-white gsap-stagger-item" onclick="readmore('<%= property._id %>')">
                    <!-- Media Gallery with luxury accents -->
                    <div class="relative overflow-hidden aspect-[4/3] w-full border-b border-border-color-light">
                        <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" src="<%= assetUrl(property.images[0]) %>" alt="<%= property.propertyName %>">
                        <!-- Luxury Rating Badge -->
                        <span class="absolute top-4 right-4 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-white/90 backdrop-blur-md text-primary font-black text-xs shadow-sm pop-3d">
                            ★ 5.0
                        </span>
                        <!-- Type Accent Gold Badge -->
                        <span class="absolute bottom-4 left-4 inline-flex px-3 py-1.5 rounded-full bg-slate-950 text-white font-bold text-[10px] tracking-wider uppercase shadow-md pop-3d">
                            <%= property.type %>
                        </span>
                    </div>

                    <!-- Luxury Real Estate Specs Line -->
                    <div class="grid grid-cols-3 border-b border-border-color-light text-text-secondary text-[11px] font-bold uppercase tracking-wider bg-bg-body-alt">
                        <div class="text-center py-3.5 border-r border-border-color-light flex items-center justify-center gap-1">
                            <i class="fa fa-bed text-primary"></i> Multi-Unit
                        </div>
                        <div class="text-center py-3.5 border-r border-border-color-light flex items-center justify-center gap-1">
                            <i class="fa fa-expand text-primary"></i> 250+ sqft
                        </div>
                        <div class="text-center py-3.5 flex items-center justify-center gap-1">
                            <i class="fa-solid fa-shield text-primary"></i> Secured
                        </div>
                    </div>

                    <!-- Info Segment -->
                    <div class="p-6 flex-1 flex flex-col gap-4 justify-between">
                        <div class="flex flex-col gap-2">
                            <h3 class="font-heading text-lg font-black group-hover:text-primary transition-colors text-text-primary line-clamp-1 uppercase tracking-wide">
                                <%= property.propertyName %>
                            </h3>
                            <p class="text-xs text-text-secondary line-clamp-3 leading-relaxed font-medium">
                                <%= property.description %>
                            </p>
                        </div>

                        <!-- Amenities quick icons -->
                        <div class="flex items-center gap-3 pt-2">
                            <span class="h-7 w-7 rounded-full bg-primary/5 text-primary text-[10px] flex items-center justify-center shadow-sm" title="Wi-Fi"><i class="fa fa-wifi"></i></span>
                            <span class="h-7 w-7 rounded-full bg-primary/5 text-primary text-[10px] flex items-center justify-center shadow-sm" title="AC Included"><i class="fa fa-snowflake"></i></span>
                            <span class="h-7 w-7 rounded-full bg-primary/5 text-primary text-[10px] flex items-center justify-center shadow-sm" title="CCTV Support"><i class="fa fa-video"></i></span>
                            <span class="h-7 w-7 rounded-full bg-primary/5 text-primary text-[10px] flex items-center justify-center shadow-sm" title="Clean Fooding"><i class="fa fa-utensils"></i></span>
                        </div>

                        <!-- CTA row inside listing -->
                        <div class="pt-4 border-t border-border-color-light flex justify-between items-center">
                            <div class="flex flex-col">
                                <span class="text-[9px] font-black text-text-secondary uppercase tracking-widest">Rate Starts At</span>
                                <span class="text-xl font-black text-primary font-heading tracking-tight">₹<%= property.price || 'Call' %> <span class="text-[10px] text-text-secondary font-medium">/mo</span></span>
                            </div>
                            <button class="px-6 py-3 bg-slate-950 hover:bg-primary hover:scale-[1.02] text-white text-xs font-black uppercase tracking-wider rounded-2xl shadow-sm transition-all cursor-pointer pop-3d" onclick="event.stopPropagation(); readmore('<%= property._id %>')">
                                Book Stay
                            </button>
                        </div>
                    </div>
                </article>
            <% }) %>
        </div>
        
        <script>
            const readmore = (propertyID) => {
                const queryString = `propertyID=${propertyID}`;
                window.location.href = `/readmore?${queryString}`;
            };
        </script>
    </section>
    <!-- Top Rooms Section End -->


    <!-- Secure Booking Banner Section Start (Overhauled to Premium Light-Canvas Layout with Trust Grids) -->
    <section class="py-16 bg-white max-w-7xl mx-auto px-6 md:px-12">
        <div class="card-3d relative w-full overflow-hidden bg-bg-body-alt rounded-[40px] p-8 md:p-16 border border-border-color/40 shadow-emerald" style="box-shadow: var(--shadow-emerald)">
            <!-- Subtle background grids & ambient light glow -->
            <div class="absolute -right-20 -bottom-20 w-80 h-80 bg-primary/4 rounded-full blur-3xl pointer-events-none"></div>
            <div class="absolute left-10 top-10 text-primary/10 text-9xl font-black select-none pointer-events-none opacity-20"><i class="fa fa-shield-halved"></i></div>
            
            <div class="relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
                <!-- Left Column: Trust Information & Grid Metrics -->
                <div class="lg:col-span-7 flex flex-col gap-6 items-start text-left">
                    <span class="text-primary font-black text-xs tracking-widest uppercase pl-8 relative before:absolute before:left-0 before:top-1/2 before:-translate-y-1/2 before:h-[2px] before:w-6 before:bg-primary">Secure Booking</span>
                    <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-black text-text-primary leading-tight tracking-tight">Instant & Fully Encrypted Reservation Portal</h2>
                    
                    <p class="text-text-secondary text-sm md:text-base leading-relaxed font-semibold">
                        Our verified transaction protocol safeguards your booking payouts. We integrate high-grade 256-bit SSL/TLS security layers and trusted UPI checkout gateways to guarantee effortless, fully protected occupancy approvals.
                    </p>
                    
                    <!-- Fintech Trust Metrics Grid -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 w-full mt-4 border-t border-border-color/20 pt-6">
                        <div class="flex items-start gap-3.5">
                            <div class="h-10 w-10 rounded-xl bg-primary/10 text-primary flex items-center justify-center text-lg shadow-sm shrink-0">
                                <i class="fa fa-lock"></i>
                            </div>
                            <div>
                                <h4 class="font-heading text-xs font-black text-text-primary uppercase tracking-wider">Bank-Grade SSL</h4>
                                <p class="text-[11px] text-text-secondary font-medium mt-1 leading-relaxed">256-Bit end-to-end encrypted occupancy lease checks.</p>
                            </div>
                        </div>

                        <div class="flex items-start gap-3.5">
                            <div class="h-10 w-10 rounded-xl bg-primary/10 text-primary flex items-center justify-center text-lg shadow-sm shrink-0">
                                <i class="fa-brands fa-upi"></i>
                            </div>
                            <div>
                                <h4 class="font-heading text-xs font-black text-text-primary uppercase tracking-wider">UPI Channels</h4>
                                <p class="text-[11px] text-text-secondary font-medium mt-1 leading-relaxed">Pay secure rentals through all major platforms instantly.</p>
                            </div>
                        </div>

                        <div class="flex items-start gap-3.5">
                            <div class="h-10 w-10 rounded-xl bg-primary/10 text-primary flex items-center justify-center text-lg shadow-sm shrink-0">
                                <i class="fa fa-circle-check"></i>
                            </div>
                            <div>
                                <h4 class="font-heading text-xs font-black text-text-primary uppercase tracking-wider">100% Certified Stays</h4>
