<%- include('partials/header') %>

<div class="p-6 space-y-6 animate-fade-in-up">
  <!-- Title / Actions Header -->
  <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-border-color pb-4">
    <div>
      <h1 class="text-3xl font-extrabold font-heading text-primary">Owner Onboarding Requests</h1>
      <p class="text-text-secondary text-sm mt-1">Verify contact credentials, sample contracts, and confirm or cancel new PG listings.</p>
    </div>
    <div class="flex items-center gap-2 bg-primary/10 text-primary border border-primary/20 rounded-xl px-4 py-2 text-xs font-semibold self-start md:self-auto">
      <i class="fa-solid fa-file-signature animate-pulse"></i>
      Pending Approvals Desk
    </div>
  </div>

  <!-- Listings Table Wrapper -->
  <div class="glass-panel rounded-2xl overflow-hidden shadow-xl border border-border-color">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse bg-bg-card">
        <thead>
          <tr class="bg-primary text-white">
            <th class="p-4 font-heading font-semibold text-sm">Property Name</th>
            <th class="p-4 font-heading font-semibold text-sm">Contact Number</th>
            <th class="p-4 font-heading font-semibold text-sm">Accommodation Type</th>
            <th class="p-4 font-heading font-semibold text-sm">Sample Contract</th>
            <th class="p-4 font-heading font-semibold text-sm">Status</th>
            <th class="p-4 font-heading font-semibold text-sm text-center">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border-color">
          <% if (owners && owners.length > 0) { %>
            <% owners.forEach(owner => { %>
              <tr class="hover:bg-primary/5 transition-colors duration-200">
                <td class="p-4 font-semibold text-text-primary">
                  <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-full bg-primary/10 text-primary flex items-center justify-center font-bold">
                      <i class="fa-solid fa-hotel text-xs"></i>
                    </div>
                    <span><%= owner.propertyName %></span>
                  </div>
                </td>
                <td class="p-4 text-sm font-mono text-text-secondary"><%= owner.contactNumber %></td>
                <td class="p-4 text-sm font-semibold capitalize text-text-secondary"><%= owner.type %></td>
                <td class="p-4 text-sm">
                  <% if (owner.tenantContract) { %>
                    <a href="<%= assetUrl(owner.tenantContract) %>" target="_blank" class="inline-flex items-center gap-1.5 text-xs text-primary hover:text-primary-hover font-semibold transition-colors duration-200">
                      <i class="fa-solid fa-file-pdf"></i>
                      <%= owner.tenantContract.split('/').pop() %>
                    </a>
                  <% } else { %>
                    <span class="text-xs text-text-secondary italic">No Upload</span>
                  <% } %>
                </td>
                <td class="p-4 text-sm">
                  <% 
                    let statusBadge = "bg-amber-500/10 text-amber-500 border border-amber-500/20";
                    if (owner.status.toLowerCase().includes('confirm') || owner.status.toLowerCase().includes('approved') || owner.status.toLowerCase().includes('active')) {
                      statusBadge = "bg-emerald-500/10 text-emerald-500 border border-emerald-500/20";
                    } else if (owner.status.toLowerCase().includes('cancel') || owner.status.toLowerCase().includes('decline')) {
                      statusBadge = "bg-red-500/10 text-red-500 border border-red-500/20";
                    }
                  %>
                  <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider <%= statusBadge %>">
                    <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
                    <%= owner.status %>
                  </span>
                </td>
                <td class="p-4 text-center">
                  <div class="flex items-center justify-center gap-2">
                    <form action="/admin/confirm/<%= owner._id %>" method="POST" style="display:inline;">
                      <button type="submit" class="bg-emerald-500 hover:bg-emerald-600 text-white text-xs font-bold px-3 py-2 rounded-xl shadow-md shadow-emerald-500/20 hover:shadow-emerald-500/35 transition-all duration-300 cursor-pointer">
                        <i class="fa-solid fa-circle-check mr-0.5"></i> Confirm
                      </button>
                    </form>
                    <form action="/admin/cancel/<%= owner._id %>" method="POST" style="display:inline;">
                      <button type="submit" class="bg-red-500 hover:bg-red-600 text-white text-xs font-bold px-3 py-2 rounded-xl shadow-md shadow-red-500/20 hover:shadow-red-500/35 transition-all duration-300 cursor-pointer">
                        <i class="fa-solid fa-circle-xmark mr-0.5"></i> Cancel
                      </button>
                    </form>
                    <a href="/admin/view/<%= owner._id %>" class="bg-bg-body hover:bg-border-color border border-border-color text-text-primary text-xs font-bold px-3 py-2 rounded-xl transition-all duration-300 flex items-center justify-center gap-0.5">
                      <i class="fa-solid fa-eye text-primary"></i> View
                    </a>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="6" class="p-12 text-center text-text-secondary font-medium">
                <i class="fa-solid fa-file-circle-exclamation text-4xl text-border-color mb-3 block animate-pulse"></i>
                No pending onboarding requests found.
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Close Sidebar & Main wrappers opened in partials/header -->
      </div>
   </div>

<!-- vendor scripts -->
<script src="<%= assetUrl('assets/vendors/js/vendor.bundle.base.js') %>"></script>
<script src="<%= assetUrl('assets/js/material.js') %>"></script>
<script src="<%= assetUrl('assets/js/misc.js') %>"></script>
</body>
</html>
