<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Property Owner Dashboard - FMPG</title>
  <link rel="icon" href="/img/logo.png" type="image/icon type">
  
  <!-- Central Tailwind CSS & Theme Config -->
  <%- include('tailwind-head') %>
  
  <script>
    function confirmAction(action, event) {
      event.preventDefault();
      const confirmation = confirm(`Are you sure you want to ${action} this booking?`);
      if (confirmation) {
        event.target.submit();
      }
    }
  </script>
</head>

<body class="bg-bg-body text-text-primary min-h-screen flex flex-col transition-colors duration-300">
  <!-- Header -->
  <%- include('header') %>

  <!-- Main Portal Workspace -->
  <main class="flex-grow py-12 px-4 md:px-8 max-w-6xl mx-auto w-full">
    <div class="glass-panel rounded-3xl p-8 shadow-2xl relative overflow-hidden animate-fade-in-up">
      <!-- Decorative Backdrop Blur -->
      <div class="absolute -top-12 -right-12 w-48 h-48 bg-primary/10 rounded-full blur-3xl"></div>
      
      <div class="relative z-10 space-y-8">
        <!-- Dashboard Intro Header -->
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-border-color pb-6">
          <div>
            <h1 class="text-3xl font-extrabold font-heading text-primary">Welcome, Property Owner</h1>
            <p class="text-text-secondary mt-1">Manage guest reserves, confirm requests, and track check-ins for your PG accommodations.</p>
          </div>
          <div class="flex items-center gap-2 bg-primary/10 text-primary border border-primary/25 rounded-2xl px-4 py-2 text-sm font-semibold self-start md:self-auto">
            <i class="fa-solid fa-hotel"></i>
            Active Properties Portal
          </div>
        </div>

        <!-- Bookings Section -->
        <div>
          <h2 class="text-xl font-bold font-heading mb-4 flex items-center gap-2">
            <i class="fa-solid fa-list-check text-primary"></i>
            Bookings for Your Properties
          </h2>

          <div class="overflow-x-auto rounded-2xl border border-border-color shadow-lg">
            <table class="w-full text-left border-collapse bg-bg-card">
              <thead>
                <tr class="bg-primary text-white">
                  <th class="p-4 font-heading font-semibold text-sm">Booking ID</th>
                  <th class="p-4 font-heading font-semibold text-sm">Property</th>
                  <th class="p-4 font-heading font-semibold text-sm">User</th>
                  <th class="p-4 font-heading font-semibold text-sm">Status</th>
                  <th class="p-4 font-heading font-semibold text-sm text-center">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-border-color">
                <% if (bookings && bookings.length > 0) { %>
                  <% bookings.forEach(booking => { %>
                    <tr class="hover:bg-primary/5 transition-colors duration-200">
                      <td class="p-4 text-xs font-mono font-bold text-text-primary"><%= booking._id %></td>
                      <td class="p-4 text-sm font-semibold text-text-primary">
                        <%= booking.propertyID && booking.propertyID.propertyName ? booking.propertyID.propertyName : 'N/A' %>
                      </td>
                      <td class="p-4 text-sm text-text-secondary font-medium"><%= booking.username %></td>
                      <td class="p-4 text-sm">
                        <!-- Status Badge -->
                        <% 
                          let badgeClass = "bg-amber-500/10 text-amber-500 border border-amber-500/25";
                          if (booking.status.toLowerCase().includes('confirm') || booking.status.toLowerCase().includes('accept')) {
                            badgeClass = "bg-emerald-500/10 text-emerald-500 border border-emerald-500/25";
                          } else if (booking.status.toLowerCase().includes('decline') || booking.status.toLowerCase().includes('cancel')) {
                            badgeClass = "bg-red-500/10 text-red-500 border border-red-500/25";
                          }
                        %>
                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider <%= badgeClass %>">
                          <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
                          <%= booking.status %>
                        </span>
                      </td>
                      <td class="p-4 text-center">
                        <% if (booking.status === 'Pending waiting for owner confirmation') { %>
                          <div class="flex items-center justify-center gap-2">
                            <form action="/owner/bookings/<%= booking._id %>/accept" method="POST" style="display:inline;"
                              onsubmit="confirmAction('accept', event);">
                              <button type="submit" class="bg-emerald-500 hover:bg-emerald-600 text-white text-xs font-bold px-4 py-2 rounded-xl shadow-md shadow-emerald-500/20 hover:shadow-emerald-500/35 transition-all duration-300">
                                Accept
                              </button>
                            </form>
                            <form action="/owner/bookings/<%= booking._id %>/decline" method="POST" style="display:inline;"
                              onsubmit="confirmAction('decline', event);">
                              <button type="submit" class="bg-red-500 hover:bg-red-600 text-white text-xs font-bold px-4 py-2 rounded-xl shadow-md shadow-red-500/20 hover:shadow-red-500/35 transition-all duration-300">
                                Decline
                              </button>
                            </form>
                          </div>
                        <% } else { %>
                          <span class="text-xs font-semibold text-text-secondary capitalize">
                            Handled
                          </span>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="5" class="p-8 text-center text-text-secondary font-medium">
                      <i class="fa-solid fa-folder-open text-3xl text-border-color mb-3 block"></i>
                      No bookings found for your properties.
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <%- include('footer') %>
</body>

</html>