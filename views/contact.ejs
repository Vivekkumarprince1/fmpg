<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>Contact Us - FMPG</title>
    <!-- Include central Tailwind Configuration -->
    <%- include('tailwind-head') %>
</head>

<body class="bg-bg-body text-text-primary transition-colors duration-300">

    <!-- Header Start -->
    <%- include('header') %>
    <!-- Header End -->

    <!-- Contact Section Start -->
    <main class="py-20 max-w-7xl mx-auto px-6 flex flex-col gap-12">
        
        <div class="text-center flex flex-col gap-2 animate-fade-in-up">
            <span class="text-primary font-bold text-sm tracking-widest uppercase">Contact Us</span>
            <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-black text-text-primary tracking-tight">Contact For Any Query</h2>
            <p class="max-w-xl mx-auto text-text-secondary mt-2">Have a question or want to list your property? Reach out to our team and we'll get back to you immediately.</p>
        </div>

        <!-- Contact Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
            
            <!-- Left Side: Get In Touch (4 Cols) -->
            <div class="lg:col-span-4 glass-panel p-8 rounded-3xl flex flex-col gap-6 justify-between">
                <div>
                    <h3 class="font-heading text-2xl font-black text-text-primary mb-3">Get In Touch</h3>
                    <p class="text-text-secondary text-sm font-semibold mb-6">Room No. 111, boys hostel, UIET Hoshiarpur, India</p>
                </div>

                <div class="flex flex-col gap-6">
                    <!-- Phone info -->
                    <div class="flex items-center gap-4">
                        <div class="h-12 w-12 rounded-2xl bg-primary/10 text-primary flex items-center justify-center text-xl shrink-0">
                            <i class="fa fa-phone-alt"></i>
                        </div>
                        <div>
                            <h4 class="text-xs text-text-secondary font-bold uppercase tracking-wider">Mobile</h4>
                            <a href="tel:+917321835093" class="text-text-primary font-bold hover:text-primary transition-colors">+91 7321835093</a>
                        </div>
                    </div>

                    <!-- Email info -->
                    <div class="flex items-center gap-4">
                        <div class="h-12 w-12 rounded-2xl bg-primary/10 text-primary flex items-center justify-center text-xl shrink-0">
                            <i class="fa fa-envelope-open"></i>
                        </div>
                        <div>
                            <h4 class="text-xs text-text-secondary font-bold uppercase tracking-wider">Email</h4>
                            <a href="mailto:contact@fmpg.in" class="text-text-primary font-bold hover:text-primary transition-colors">contact@fmpg.in</a>
                        </div>
                    </div>
                </div>
                
                <p class="text-xs text-text-secondary font-medium border-t border-border-color pt-6"><i class="fa fa-clock text-primary mr-1"></i> Support hours: 9:00 AM - 9:00 PM IST</p>
            </div>

            <!-- Middle Side: Map Frame (4 Cols) -->
            <div class="lg:col-span-4 rounded-3xl overflow-hidden border border-border-color shadow-lg min-h-[300px]">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3401.2131051011565!2d75.96845537463533!3d31.51830644724575!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x391ae3c79f844049%3A0x82fa7fd53084f7e4!2sUIET%20HOSHIARPUR!5e0!3m2!1sen!2sin!4v1719298375813!5m2!1sen!2sin" class="w-full h-full min-h-[300px]" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>

            <!-- Right Side: Contact Form (4 Cols) -->
            <div class="lg:col-span-4 glass-panel p-8 rounded-3xl bg-bg-card border-border-color">
                <form action="/contact" method="POST" class="flex flex-col gap-4">
                    <!-- Name & Email Row -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div class="flex flex-col gap-1">
                            <label for="name" class="text-xs font-bold text-text-secondary">Your Name</label>
                            <input type="text" id="name" name="name" class="w-full bg-bg-body border border-border-color rounded-xl py-3 px-4 text-sm font-semibold focus:outline-none focus:border-primary text-text-primary transition-colors" placeholder="Vikas" required>
                        </div>
                        <div class="flex flex-col gap-1">
                            <label for="email" class="text-xs font-bold text-text-secondary">Your Email</label>
                            <input type="email" id="email" name="email" class="w-full bg-bg-body border border-border-color rounded-xl py-3 px-4 text-sm font-semibold focus:outline-none focus:border-primary text-text-primary transition-colors" placeholder="vikas@fmpg.com" required>
                        </div>
                    </div>

                    <!-- Subject -->
                    <div class="flex flex-col gap-1">
                        <label for="subject" class="text-xs font-bold text-text-secondary">Subject</label>
                        <input type="text" id="subject" name="subject" class="w-full bg-bg-body border border-border-color rounded-xl py-3 px-4 text-sm font-semibold focus:outline-none focus:border-primary text-text-primary transition-colors" placeholder="Listing query" required>
                    </div>

                    <!-- Message text -->
                    <div class="flex flex-col gap-1">
                        <label for="message" class="text-xs font-bold text-text-secondary">Message</label>
                        <textarea id="message" name="message" rows="4" class="w-full bg-bg-body border border-border-color rounded-xl py-3 px-4 text-sm font-semibold focus:outline-none focus:border-primary text-text-primary transition-colors resize-none" placeholder="Leave a message here..." required></textarea>
                    </div>

                    <!-- Submit -->
                    <button type="submit" class="w-full py-3.5 bg-primary hover:bg-primary-hover text-white font-bold rounded-xl shadow-md shadow-primary/10 transition-colors cursor-pointer mt-2">
                        Send Message
                    </button>
                </form>
            </div>
        </div>
    </main>
    <!-- Contact Section End -->

    <!-- Footer Start -->
    <%- include('footer') %>
    <!-- Footer End -->

    <!-- Main JavaScript -->
    <script src="js/main.js"></script>
</body>

</html>