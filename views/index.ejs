    <!-- Page Specific Script binds -->
    <script src="js/main.js"></script>
    <script src="/js/locationScript.js"></script>
    <script>
        // Automatic Fade-Out logic for dynamic alerts
        setTimeout(function () {
            const alertMessage = document.getElementById('message-alert');
            if (alertMessage) {
                setTimeout(() => alertMessage.remove(), 1000); // Remove from DOM fully after fade-out transition completes
            }
        }, 4000);

        // Near-Me dynamic GPS redirect script binding
        const searchButton = document.getElementById('search-btn');
        if (searchButton) {
            searchButton.addEventListener('click', function () {
                const inputVal = document.getElementById('input').value.trim();
                const userLat = sessionStorage.getItem('userLat');
                const userLng = sessionStorage.getItem('userLng');
                if (inputVal) {
                    window.location.href = `/search-page?query=${encodeURIComponent(inputVal)}`;
                } else if (userLat && userLng) {
                    window.location.href = `/search-page?lat=${userLat}&lng=${userLng}`;
                } else {
                    alert("Please enter a location query or use Detect Location.");
                }
            });
        }
    </script>
